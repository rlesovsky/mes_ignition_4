    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Label"
            },
            "position": {
              "basis": "300px"
            },
            "props": {
              "text": "Line 1 Production",
              "textStyle": {
                "color": "#ffffff",
                "fontFamily": "Arial",
                "fontSize": 18,
                "fontWeight": "600",
                "marginLeft": 10
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Label_1"
            },
            "position": {
              "basis": "30px",
              "grow": 1
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "fallbackDelay": 2.5,
                    "mode": "direct",
                    "tagPath": "[default]Enterprise/Site/Area/Line 1/Edge/State"
                  },
                  "transforms": [
                    {
                      "fallback": null,
                      "inputType": "scalar",
                      "mappings": [
                        {
                          "input": 0,
                          "output": "Stopped"
                        },
                        {
                          "input": 1,
                          "output": "Running"
                        },
                        {
                          "input": 2,
                          "output": "E-Stop"
                        },
                        {
                          "input": 3,
                          "output": "Blocked"
                        },
                        {
                          "input": 4,
                          "output": "Starved"
                        },
                        {
                          "input": 5,
                          "output": "Change Over"
                        }
                      ],
                      "outputType": "scalar",
                      "type": "map"
                    }
                  ],
                  "type": "tag"
                }
              },
              "props.textStyle.color": {
                "binding": {
                  "config": {
                    "path": "this.props.text"
                  },
                  "transforms": [
                    {
                      "fallback": "#EF4444",
                      "inputType": "scalar",
                      "mappings": [
                        {
                          "input": "Running",
                          "output": "#10B981"
                        }
                      ],
                      "outputType": "color",
                      "type": "map"
                    }
                  ],
                  "type": "property"
                }
              }
            },
            "props": {
              "textStyle": {
                "fontFamily": "Arial",
                "fontSize": 18,
                "fontWeight": "600",
                "marginLeft": 10
              }
            },
            "type": "ia.display.label"
