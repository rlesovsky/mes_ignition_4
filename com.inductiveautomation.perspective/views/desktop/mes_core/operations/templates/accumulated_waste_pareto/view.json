              "transforms": [
                {
                  "code": "\n\tlogger = system.util.getLogger(\"WasteCountChart\")\n\t\n\ttry:\n\t\t# Get view parameter for runID\n\t\trunID = self.view.custom.runID if hasattr(self.view.custom, 'runID') else 1\n\t\t\n\t\tlogger.info(\"Query parameter - RunID: {}\".format(runID))\n\t\t\n\texcept Exception as e:\n\t\tlogger.error(\"Parameter error: \" + str(e))\n\t\treturn {\"waste_data\": []}\n\t\n\ttry:\n\t\tsql_query = \"\"\"\n\t\tSELECT EXTRACT(HOUR FROM \\\"TimeStamp\\\") as Hour, sum(count) as Actual \n\t\tFROM counthistory\n\t\tWHERE counttypeid = 3\n\t\t  AND runid = ?\n\t\tGROUP BY DATE(\\\"TimeStamp\\\"), EXTRACT(HOUR FROM \\\"TimeStamp\\\")\n\t\tORDER BY DATE(\\\"TimeStamp\\\") DESC, EXTRACT(HOUR FROM \\\"TimeStamp\\\") DESC\n\t\tLIMIT 8\n\t\t\"\"\"\n\t\t\n\t\tdataset = system.db.runPrepQuery(sql_query, [runID], 'mes_core')\n\t\t\n\t\tlogger.info(\"Query executed, found {} rows\".format(dataset.getRowCount()))\n\t\t\n\t\tresult = []\n\t\tfor row in range(dataset.getRowCount()):\n\t\t\thour = dataset.getValueAt(row, \"Hour\")\n\t\t\tactual = dataset.getValueAt(row, \"Actual\")\n\t\t\t\n\t\t\tif hour is not None and actual is not None:\n\t\t\t\tresult.append({\n\t\t\t\t\t\"Hour\": \"{}:00\".format(int(hour)),  # Format as \"14:00\", \"15:00\", etc.\n\t\t\t\t\t\"Actual\": int(actual)\n\t\t\t\t})\n\t\t\t\tlogger.info(\"Added: Hour {} = {} units\".format(hour, actual))\n\t\t\n\t\t# Reverse to show chronological order (oldest to newest)\n\t\tresult.reverse()\n\t\t\n\t\treturn {\"waste_data\": result}\n\t\t\n\texcept Exception as e:\n\t\tlogger.error(\"Query error: \" + str(e))\n\t\treturn {\"waste_data\": []}",
                  "type": "script"
                }
              ],
              "type": "expr"
            }
