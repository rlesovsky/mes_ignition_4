        "propConfig": {
          "props.data": {
            "binding": {
              "config": {
                "fallbackDelay": 2.5,
                "mode": "expression",
                "tagPath": "now()"
              },
              "transforms": [
                {
                  "code": "\n    # Define database name\n    dbName = \"mes_core\"\n    \n    # Define the query with parameters for startTime and lineID\n    query = \"\"\"\n        SELECT s.id AS \\\"ID\\\", s.reasonname AS \\\"ReasonName\\\", s.reasoncode AS \\\"ReasonCode\\\", s.startdatetime AS \\\"StartDateTime\\\", s.enddatetime AS \\\"EndDateTime\\\",\n               EXTRACT(EPOCH FROM (s.enddatetime - s.startdatetime)) AS \\\"Total in Seconds\\\", s.note AS \\\"Note\\\"\n        FROM statehistory s\n        LEFT JOIN statereason st\n        ON s.statereasonid = st.id\n        WHERE (st.recorddowntime = true\n        AND s.startdatetime >= ?\n        AND (s.enddatetime < CURRENT_TIMESTAMP AND s.enddatetime > s.startdatetime)\n        AND s.lineid = ?)\n        OR (st.recorddowntime = true AND s.lineid = ? AND s.enddatetime IS NULL)\n        ORDER BY s.startdatetime DESC\n    \"\"\"\n    \n    try:\n        # Get parameters from Perspective properties (adjust paths as needed)\n        startTime = system.tag.readBlocking(\"[default]Enterprise/Site/Area/Line 1/Line/Start Time\")[0].value # Assuming datetime string in 'YYYY-MM-DD HH:MM:SS' format\n        lineID = 1  # Assuming integer\n        \n        # Parameters: startTime, lineID (for first AND), lineID (for OR)\n        params = [startTime, lineID, lineID]\n        \n        # Execute the query\n        data = system.db.runPrepQuery(query, params, dbName)\n        \n        # Get column names from the dataset\n        column_names = data.getColumnNames()\n        \n        # Convert dataset to JSON for Perspective compatibility\n        json_data = system.dataset.toPyDataSet(data)\n        \n        # Check if there's data\n        if data.getRowCount() > 0:\n            # Return data with all rows\n            result = [\n                {\n                    col: row[col]\n                    for col in column_names\n                }\n                for row in json_data\n            ]\n        else:\n            # Return empty row with column headers (None values)\n            result = [\n                {\n                    col: None\n                    for col in column_names\n                }\n            ]\n        \n        return result\n        \n    except Exception as e:\n        system.util.getLogger(\"ScriptLogger\").error(\"Query failed: {}\".format(str(e)))\n        # Return empty structure with expected column headers\n        return [\n            {\n                'ID': None,\n                'ReasonName': None,\n                'ReasonCode': None,\n                'StartDateTime': None,\n                'EndDateTime': None,\n                'Total in Seconds': None,\n                'Note': None\n            }\n        ]",
                  "type": "script"
                }
              ],
              "type": "tag"
            }
          }
        },
