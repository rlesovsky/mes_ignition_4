                  "transforms": [
                    {
                      "code": "\tif value is None:\n\t\treturn \"0%\"\n\ttry:\n\t\tpercentage = float(value) * 100 if float(value) <= 1 else float(value)\n\t\treturn str(int(round(percentage))) + \"%\"\n\texcept (ValueError, TypeError):\n\t\treturn \"0%\"",
