            "meta": {
              "name": "status_availability"
            },
            "position": {
              "grow": 1
            },
            "propConfig": {
              "props.style.color": {
                "binding": {
                  "config": {
                    "path": "../gauges_row/gauge_availability.props.value"
                  },
                  "transforms": [
                    {
                      "code": "\t\"\"\"\n\tTransform OEE percentage (0-100) to color hex codes\n\t\"\"\"\n\tif value is None:\n\t\treturn \"#6b7280\"\n\ttry:\n\t\tvalue_str = str(value).strip()\n\t\tif value_str.endswith('%'):\n\t\t\tvalue_str = value_str[:-1]\n\t\tpercentage = float(value_str)\n\texcept (ValueError, TypeError):\n\t\treturn \"#6b7280\"\n\tpercentage = max(0, min(100, percentage))\n\tif percentage >= 85:\n\t\treturn \"#10b981\"\n\telif percentage >= 70:\n\t\treturn \"#3b82f6\"\n\telif percentage >= 50:\n\t\treturn \"#f59e0b\"\n\telif percentage >= 30:\n\t\treturn \"#f97316\"\n\telse:\n\t\treturn \"#ef4444\"",
                      "type": "script"
                    }
                  ],
                  "type": "property"
                }
              },
              "props.text": {
                "binding": {
                  "config": {
                    "path": "../gauges_row/gauge_availability.props.value"
                  },
                  "transforms": [
                    {
                      "code": "\t\"\"\"\n\tTransform OEE percentage (0-100) to status text\n\t\"\"\"\n\tif value is None:\n\t\treturn \"No Data\"\n\ttry:\n\t\tvalue_str = str(value).strip()\n\t\tif value_str.endswith('%'):\n\t\t\tvalue_str = value_str[:-1]\n\t\tpercentage = float(value_str)\n\texcept (ValueError, TypeError):\n\t\treturn \"Invalid\"\n\tpercentage = max(0, min(100, percentage))\n\tif percentage >= 85:\n\t\treturn \"Excellent\"\n\telif percentage >= 70:\n\t\treturn \"Good\"\n\telif percentage >= 50:\n\t\treturn \"Average\"\n\telif percentage >= 30:\n\t\treturn \"Needs Improvement\"\n\telse:\n\t\treturn \"Critical\"",
                      "type": "script"
                    }
                  ],
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "fontFamily": "Arial",
                "fontSize": 12,
