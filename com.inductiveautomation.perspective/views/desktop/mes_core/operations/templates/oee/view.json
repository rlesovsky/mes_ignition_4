            "position": {
              "grow": 1,
              "basis": "150px"
            },
            "props": {
              "startAngle": 0,
              "arc": {
                "width": 5
              },
              "arcBackground": {},
              "label": {
                "size": 42,
                "offsetY": 20,
                "color": "#d1d5db",
                "maxDecimal": 0
              },
              "style": {
                "padding": 8
              }
            },
            "propConfig": {
              "props.arc.color": {
                "binding": {
                  "type": "property",
                  "config": {
                    "path": "this.props.value"
                  },
                  "transforms": [
                    {
                      "type": "script",
                      "code": "\tif value is None:\n\t\treturn \"#6b7280\"\n\ttry:\n\t\tvalue_str = str(value).strip()\n\t\tif value_str.endswith('%'):\n\t\t\tvalue_str = value_str[:-1]\n\t\tpercentage = float(value_str)\n\texcept (ValueError, TypeError):\n\t\treturn \"#6b7280\"\n\tpercentage = max(0, min(100, percentage))\n\tif percentage >= 85:\n\t\treturn \"#10b981\"\n\telif percentage >= 70:\n\t\treturn \"#3b82f6\"\n\telif percentage >= 50:\n\t\treturn \"#f59e0b\"\n\telif percentage >= 30:\n\t\treturn \"#f97316\"\n\telse:\n\t\treturn \"#ef4444\""
                    }
                  ]
                }
              },
              "props.arcBackground.color": {
                "binding": {
                  "type": "property",
                  "config": {
                    "path": "this.props.value"
                  },
                  "transforms": [
                    {
                      "type": "script",
                      "code": "\tif value is None:\n\t\treturn \"rgba(107, 114, 128, 0.2)\"\n\ttry:\n\t\tvalue_str = str(value).strip()\n\t\tif value_str.endswith('%'):\n\t\t\tvalue_str = value_str[:-1]\n\t\tpercentage = float(value_str)\n\texcept (ValueError, TypeError):\n\t\treturn \"rgba(107, 114, 128, 0.2)\"\n\tpercentage = max(0, min(100, percentage))\n\tif percentage >= 85:\n\t\treturn \"rgba(16, 185, 129, 0.2)\"\n\telif percentage >= 70:\n\t\treturn \"rgba(59, 130, 246, 0.2)\"\n\telif percentage >= 50:\n\t\treturn \"rgba(245, 158, 11, 0.2)\"\n\telif percentage >= 30:\n\t\treturn \"rgba(249, 115, 22, 0.2)\"\n\telse:\n\t\treturn \"rgba(239, 68, 68, 0.2)\""
                    }
                  ]
                }
              },
              "props.value": {
                "binding": {
                  "type": "tag",
                  "config": {
                    "fallbackDelay": 2.5,
                    "mode": "expression",
                    "tagPath": "{view.params.tagPath} + \"/Line/OEE/OEE\""
                  },
                  "transforms": [
                    {
                      "type": "format",
                      "formatType": "numeric",
                      "formatValue": "percent"
                    }
                  ]
                }
              }
            }
          }
        ]
      }
    ]
  }
