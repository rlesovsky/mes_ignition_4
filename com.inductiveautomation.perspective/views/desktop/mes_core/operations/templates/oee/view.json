                    {
                      "type": "script",
                      "code": "\tif value is None:\n\t\treturn \"No Data\"\n\ttry:\n\t\tvalue_str = str(value).strip()\n\t\tif value_str.endswith('%'):\n\t\t\tvalue_str = value_str[:-1]\n\t\tpercentage = float(value_str)\n\texcept (ValueError, TypeError):\n\t\treturn \"Invalid\"\n\tpercentage = max(0, min(100, percentage))\n\tif percentage >= 85:\n\t\treturn \"Excellent\"\n\telif percentage >= 70:\n\t\treturn \"Good\"\n\telif percentage >= 50:\n\t\treturn \"Average\"\n\telif percentage >= 30:\n\t\treturn \"Needs Improvement\"\n\telse:\n\t\treturn \"Critical\""
