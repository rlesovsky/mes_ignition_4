      {
        "meta": {
          "name": "status_labels_row"
        },
        "position": {
          "basis": "20px",
          "shrink": 0
        },
        "props": {
          "alignItems": "center",
          "style": {
            "marginBottom": 4
          }
        },
        "type": "ia.container.flex",
        "children": [
          {
            "meta": {
              "name": "status_availability"
            },
            "position": {
              "grow": 1
            },
            "propConfig": {
              "props.style.color": {
                "binding": {
                  "config": {
                    "fallbackDelay": 2.5,
                    "mode": "expression",
                    "tagPath": "{view.params.tagPath} + \"/Line/OEE/OEE Availability\""
                  },
                  "transforms": [
                    {
                      "code": "\tif value is None:\n\t\treturn \"#6b7280\"\n\ttry:\n\t\tpercentage = float(value) * 100 if float(value) <= 1 else float(value)\n\texcept (ValueError, TypeError):\n\t\treturn \"#6b7280\"\n\tpercentage = max(0, min(100, percentage))\n\tif percentage >= 85:\n\t\treturn \"#10b981\"\n\telif percentage >= 70:\n\t\treturn \"#3b82f6\"\n\telif percentage >= 50:\n\t\treturn \"#f59e0b\"\n\telif percentage >= 30:\n\t\treturn \"#f97316\"\n\telse:\n\t\treturn \"#ef4444\"",
                      "type": "script"
                    }
                  ],
                  "type": "tag"
                }
              },
              "props.text": {
                "binding": {
                  "config": {
                    "fallbackDelay": 2.5,
                    "mode": "expression",
                    "tagPath": "{view.params.tagPath} + \"/Line/OEE/OEE Availability\""
                  },
                  "transforms": [
                    {
                      "code": "\tif value is None:\n\t\treturn \"No Data\"\n\ttry:\n\t\tpercentage = float(value) * 100 if float(value) <= 1 else float(value)\n\texcept (ValueError, TypeError):\n\t\treturn \"Invalid\"\n\tpercentage = max(0, min(100, percentage))\n\tif percentage >= 85:\n\t\treturn \"Excellent\"\n\telif percentage >= 70:\n\t\treturn \"Good\"\n\telif percentage >= 50:\n\t\treturn \"Average\"\n\telif percentage >= 30:\n\t\treturn \"Needs Improvement\"\n\telse:\n\t\treturn \"Critical\"",
                      "type": "script"
                    }
                  ],
                  "type": "tag"
                }
              }
            },
            "props": {
              "style": {
                "classes": "labels/font",
                "fontSize": 12,
                "fontWeight": 600,
                "textAlign": "center"
              }
            },
            "type": "ia.display.label"
          },
