{
  "custom": {
    "oeeColorScript": "\"\"\"\nOEE Color Transform - Reusable script for consistent color coding\nUsed by both arc colors and status text colors\n\nColor Mapping:\n  85-100%: Excellent (Green) - #10b981\n  70-84%:  Good (Blue) - #3b82f6\n  50-69%:  Average (Yellow) - #f59e0b\n  30-49%:  Poor (Orange) - #f97316\n  0-29%:   Critical (Red) - #ef4444\n\"\"\""
  },
  "params": {
    "tagPath": "[default]Enterprise/Site/Area/Line 1"
  },
  "propConfig": {
    "params.tagPath": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 280,
      "width": 650
    }
  },
