    "custom.unitScheduled": {
      "binding": {
        "config": {
          "expression": "now()"
        },
        "transforms": [
          {
            "code": "\n    # Define database name\n    dbName \u003d \"mes_core\"\n    \n    # Base query with parameterized WorkOrderID\n    query \u003d \"\"\"\n        SELECT SUM(Quantity) AS TotalQuantity\n        FROM schedule\n        WHERE WorkOrderID \u003d ?\n    \"\"\"\n    \n    params \u003d []\n    try:\n        # Get WorkOrderID from root container property\n        workOrderID \u003d self.custom.workOrders[0].ID\n        \n        params.append(workOrderID)\n        \n        # Execute the query\n        data \u003d system.db.runPrepQuery(query, params, dbName)\n        \n        # Convert dataset to JSON for Perspective compatibility\n        json_data \u003d system.dataset.toPyDataSet(data)\n        result \u003d [\n            {\n                col: row[col]\n                for col in data.getColumnNames()\n            }\n            for row in json_data\n        ]\n        return result\n        \n    except Exception as e:\n        system.util.getLogger(\"ScriptLogger\").error(\"Query failed: {}\".format(str(e)))\n        return []",
            "type": "script"
          }
        ],
        "type": "expr"
      },
      "persistent": true
    },
    "custom.workOrder": {
      "binding": {
        "config": {
          "expression": "now()"
        },
        "transforms": [
          {
            "code": "\n    # Define database name\n    dbName \u003d \"mes_core\"\n    \n    # Base query with parameterized ID\n    query \u003d \"\"\"\n        SELECT ID, WorkOrer\n        FROM workorder\n        WHERE ID \u003d ?\n    \"\"\"\n    \n    params \u003d []\n    try:\n        # Get workOrderID from root container property\n        workOrderID \u003d self.custom.workOrders[0].WorkOrderID\n        \n        params.append(workOrderID)\n        \n        # Execute the query\n        data \u003d system.db.runPrepQuery(query, params, dbName)\n        \n        # Convert dataset to JSON for Perspective compatibility\n        json_data \u003d system.dataset.toPyDataSet(data)\n        result \u003d [\n            {\n                col: row[col]\n                for col in data.getColumnNames()\n            }\n            for row in json_data\n        ]\n        return result\n        \n    except Exception as e:\n        system.util.getLogger(\"ScriptLogger\").error(\"Query failed: {}\".format(str(e)))\n        return []",
            "type": "script"
          }
        ],
        "type": "expr"
      }
    },
    "custom.workOrders": {
      "binding": {
        "config": {
          "expression": "now()"
        },
        "transforms": [
          {
            "code": "\n    # Define database name\n    dbName \u003d \"mes_core\"\n    \n    # Base query matching your Vision query\n    query \u003d \"\"\"\n        SELECT ID, WorkOrder, ProductCode, Quantity\n        FROM workorder\n        WHERE ID \u003d ?\n    \"\"\"\n    \n    params \u003d []\n    try:\n        # Get WorkOrderID from root container property\n        workOrderID \u003d self.params.id\n        \n        params.append(workOrderID)\n        \n        # Execute the query\n        data \u003d system.db.runPrepQuery(query, params, dbName)\n        \n        # Convert dataset to JSON for Perspective compatibility\n        json_data \u003d system.dataset.toPyDataSet(data)\n        result \u003d [\n            {\n                col: row[col]\n                for col in data.getColumnNames()\n            }\n            for row in json_data\n        ]\n        return result\n        \n    except Exception as e:\n        system.util.getLogger(\"ScriptLogger\").error(\"Query failed: {}\".format(str(e)))\n        return []",
            "type": "script"
          }
        ],
        "type": "expr"
      },
      "persistent": true
    },
