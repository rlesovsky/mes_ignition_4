          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "script": "\n    # Get current timestamp and set milliseconds to 0\n    timestamp \u003d system.date.now()\n    timestamp \u003d system.date.setTime(timestamp, system.date.getHour24(timestamp), system.date.getMinute(timestamp), system.date.getSecond(timestamp))\n    \n    # Define database name\n    db \u003d \u0027mes_core\u0027\n    \n    # Define insert query\n    query \u003d \u0027\u0027\u0027INSERT INTO schedule (LineID, WorkOrderID, ScheduleType, Note, ScheduleStartDateTime, ScheduleFinishDateTime, Quantity, EnteredBy, TimeStamp) \n               VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\u0027\u0027\u0027\n    \n    # Define validation query for WorkOrderID\n    validation_query \u003d \u0027\u0027\u0027SELECT ID FROM workorder WHERE ID \u003d ?\u0027\u0027\u0027\n    \n    try:\n        # Gather parameters required to add a schedule entry\n        lineID \u003d self.view.params.lineID\n        workOrderID \u003d self.view.params.id\n        workOrder \u003d self.view.custom.workOrders[0].WorkOrder\n        scheduleType \u003d \u0027\u0027\n        startDate \u003d self.parent.parent.getChild(\"schedule\").getChild(\"DateTimeInput\").props.value\n        finishDate \u003d self.parent.parent.getChild(\"schedule\").getChild(\"DateTimeInput_0\").props.value\n        quantity \u003d self.parent.parent.getChild(\"quantity\").getChild(\"NumericEntryField\").props.value\n        userName \u003d \u0027Randy L\u0027\n        note \u003d self.parent.parent.getChild(\"notes\").getChild(\"TextArea\").props.text\n        \n        # Validate WorkOrderID exists in workorder table\n        validation_result \u003d system.db.runPrepQuery(validation_query, [workOrderID], db)\n        if validation_result.getRowCount() \u003d\u003d 0:\n            system.util.getLogger(\"ScriptLogger\").error(\"Invalid WorkOrderID: {} does not exist in workorder table\".format(workOrderID))\n            return\n        \n        # Format timestamps for database\n        timestamp_str \u003d system.date.format(timestamp, \"yyyy-MM-dd HH:mm:ss\")\n        startDate_str \u003d system.date.format(startDate, \"yyyy-MM-dd HH:mm:ss\")\n        finishDate_str \u003d system.date.format(finishDate, \"yyyy-MM-dd HH:mm:ss\")\n        \n        # Execute the insert query\n        result \u003d system.db.runPrepUpdate(query, [lineID, workOrderID, scheduleType, note, startDate_str, finishDate_str, quantity, userName, timestamp_str], db)\n        \n        # Close the popup if insert is successful\n        if result \u003d\u003d 1:\n            system.perspective.closePopup(\"\")\n            \n    except Exception as e:\n        system.util.getLogger(\"ScriptLogger\").error(\"Insert failed: {}\".format(str(e)))\n\t"
                  },
