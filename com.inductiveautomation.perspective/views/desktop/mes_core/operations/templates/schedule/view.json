            "propConfig": {
              "props.data": {
                "binding": {
                  "config": {
                    "fallbackDelay": 2.5,
                    "mode": "expression",
                    "tagPath": "now()"
                  },
                  "transforms": [
                    {
                      "code": "\n    # Define database name\n    dbName = \"mes_core\"\n    \n    # Define the query with a placeholder for the parameter\n    query = \"\"\"\n    SELECT\n    sch.id AS \\\"ID\\\",\n    wo.workorder AS \\\"Work Order\\\",\n    wo.productcode AS \\\"Product Code\\\",\n    wo.quantity AS \\\"Quantity\\\",\n    sch.schedulestartdatetime AS \\\"Start Date\\\"\n    FROM workorder wo\n    INNER JOIN schedule sch ON sch.workorderid = wo.id\n    WHERE wo.closed = false\n    AND sch.lineid = ?\n    AND sch.id NOT IN (SELECT scheduleid FROM run)\n    ORDER BY sch.schedulestartdatetime, sch.schedulefinishdatetime, wo.workorder\n    \"\"\"\n    \n    try:\n        # Read the line_id value from the client tag\n        tag_path = self.view.params.tagPath + \"/Line/Line ID\"\n        line_id_result = system.tag.readBlocking([tag_path])[0]\n        if line_id_result.quality.isGood():\n            line_id = line_id_result.value\n        else:\n            raise ValueError(\"Failed to read tag value for line_id\")\n        \n        # Execute the query with the parameter\n        data = system.db.runPrepQuery(query, [line_id], dbName)\n        \n        # Get column names from the dataset\n        column_names = data.getColumnNames()\n        \n        # Convert dataset to JSON for Perspective compatibility\n        json_data = system.dataset.toPyDataSet(data)\n        \n        # Check if there's data\n        if data.getRowCount() > 0:\n            # Return data with all rows\n            result = [\n                {\n                    col: row[col]\n                    for col in column_names\n                }\n                for row in json_data\n            ]\n        else:\n            # Return empty row with column headers (None values)\n            result = [\n                {\n                    col: None\n                    for col in column_names\n                }\n            ]\n        \n        return result\n        \n    except Exception as e:\n        system.util.getLogger(\"ScriptLogger\").error(\"Query failed: {}\".format(str(e)))\n        # Return empty structure with expected column headers\n        return [\n            {\n                'ID': None,\n                'Work Order': None,\n                'Product Code': None,\n                'Quantity': None,\n                'Start Date': None\n            }\n        ]",
                      "type": "script"
                    }
                  ],
                  "type": "tag"
                }
              }
            },
