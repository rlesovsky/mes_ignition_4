            "propConfig": {
              "props.data": {
                "binding": {
                  "config": {
                    "fallbackDelay": 2.5,
                    "mode": "expression",
                    "tagPath": "now()"
                  },
                  "transforms": [
                    {
                      "code": "\n    # Define database name\n    dbName \u003d \"mes_core\"\n    \n    # Define the query with a placeholder for the parameter\n    query \u003d \"\"\"\n    SELECT\n    sch.ID AS \u0027ID\u0027,\n    wo.WorkOrder AS `Work Order`,\n    wo.ProductCode AS \u0027Product Code\u0027,\n    wo.Quantity AS `Quantity`,\n    sch.ScheduleStartDateTime AS \u0027Start Date\u0027\n    FROM workorder wo\n    INNER JOIN schedule sch ON sch.WorkOrderID \u003d wo.ID\n    WHERE wo.Closed \u003d 0\n    AND sch.LineID \u003d ?\n    AND sch.ID NOT IN (SELECT ScheduleID FROM run)\n    ORDER BY sch.ScheduleStartDateTime, sch.ScheduleFinishDateTime, wo.workorder\n    \"\"\"\n    \n    try:\n        # Read the line_id value from the client tag\n        tag_path \u003d self.view.params.tagPath + \"/Line/Line ID\"\n        line_id_result \u003d system.tag.readBlocking([tag_path])[0]\n        if line_id_result.quality.isGood():\n            line_id \u003d line_id_result.value\n        else:\n            raise ValueError(\"Failed to read tag value for line_id\")\n        \n        # Execute the query with the parameter\n        data \u003d system.db.runPrepQuery(query, [line_id], dbName)\n        \n        # Get column names from the dataset\n        column_names \u003d data.getColumnNames()\n        \n        # Convert dataset to JSON for Perspective compatibility\n        json_data \u003d system.dataset.toPyDataSet(data)\n        \n        # Check if there\u0027s data\n        if data.getRowCount() \u003e 0:\n            # Return data with all rows\n            result \u003d [\n                {\n                    col: row[col]\n                    for col in column_names\n                }\n                for row in json_data\n            ]\n        else:\n            # Return empty row with column headers (None values)\n            result \u003d [\n                {\n                    col: None\n                    for col in column_names\n                }\n            ]\n        \n        return result\n        \n    except Exception as e:\n        system.util.getLogger(\"ScriptLogger\").error(\"Query failed: {}\".format(str(e)))\n        # Return empty structure with expected column headers\n        return [\n            {\n                \u0027ID\u0027: None,\n                \u0027Work Order\u0027: None,\n                \u0027Product Code\u0027: None,\n                \u0027Quantity\u0027: None,\n                \u0027Start Date\u0027: None\n            }\n        ]",
                      "type": "script"
                    }
                  ],
                  "type": "tag"
                }
              }
            },
