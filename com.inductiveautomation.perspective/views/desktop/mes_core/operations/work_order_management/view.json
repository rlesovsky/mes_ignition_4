                  "transforms": [
                    {
                      "code": "\n    # Define database name\n    dbName \u003d \"mes_core\"\n    \n    # Base query with join and parameterized LineID\n    query \u003d \"\"\"\n        SELECT w.ID as \u0027ID\u0027, w.WorkOrder as \u0027Work Order\u0027, w.ProductCode as \u0027Product Code\u0027, \n               w.Quantity as \u0027QTY\u0027, w.Closed as \u0027Closed\u0027, w.TimeStamp as \u0027TimeStamp\u0027 \n        FROM workorder w\n        LEFT JOIN productcode pc\n        ON w.ProductCode \u003d pc.ProductCode\n        LEFT JOIN productcodeline pcl\n        ON pc.ID \u003d pcl.ProductCodeID\n        WHERE pcl.LineID \u003d ?\n    \"\"\"\n    \n    params \u003d []\n    try:\n        # Get LineID from component property (adjust path as needed)\n        lineID \u003d 1  # Adjust based on your Perspective property path\n        \n        # Optional: Handle closed work order filter\n        includeClosed \u003d False # Assume a boolean property; adjust path as needed\n        if not includeClosed:\n            query +\u003d \" AND w.Closed \u003d 0\"\n        \n        params.append(lineID)\n        \n        # Execute the query\n        data \u003d system.db.runPrepQuery(query, params, dbName)\n        \n        # Convert dataset to JSON for Perspective compatibility\n        json_data \u003d system.dataset.toPyDataSet(data)\n        result \u003d [\n            {\n                col: row[col]\n                for col in data.getColumnNames()\n            }\n            for row in json_data\n        ]\n        return result\n        \n    except Exception as e:\n        system.util.getLogger(\"ScriptLogger\").error(\"Query failed: {}\".format(str(e)))\n        return []",
                      "type": "script"
                    }
                  ],
