          {
            "meta": {
              "name": "EquipmentSchedule"
            },
            "position": {
              "basis": "500px"
            },
            "propConfig": {
              "props.scheduledEvents": {
                "binding": {
                  "config": {
                    "expression": "now()"
                  },
                  "transforms": [
                    {
                      "code": "\n    # Define database name\n    dbName \u003d \"mes_core\"\n    \n    # Define query to fetch schedules from the last month\n    query \u003d \"\"\"\n        SELECT s.ID, s.LineID, s.WorkOrderID,\n               s.ScheduleStartDateTime AS StartDateTime,\n               s.ScheduleFinishDateTime AS FinishDateTime,\n               s.Quantity, s.ActualQuantity, w.WorkOrder\n        FROM schedule s\n        INNER JOIN workorder w ON s.WorkOrderID \u003d w.ID\n        WHERE s.ScheduleStartDateTime \u003e\u003d ? AND s.ScheduleStartDateTime \u003c\u003d ?\n    \"\"\"\n    \n    params \u003d []\n    try:\n        # Calculate date range for the last month\n        end_date \u003d system.date.now()\n        start_date \u003d system.date.addDays(end_date, -30)\n        \n        params.append(start_date)\n        params.append(end_date)\n        \n        # Execute the query\n        data \u003d system.db.runPrepQuery(query, params, dbName)\n        \n        # Convert dataset to JSON in the required format\n        json_data \u003d system.dataset.toPyDataSet(data)\n        result \u003d []\n        \n        for row in json_data:\n            # Get datetime values\n            start_date_time \u003d row[\"StartDateTime\"]\n            finish_date_time \u003d row[\"FinishDateTime\"]\n            \n            # Log what we\u0027re working with\n            system.util.getLogger(\"ScriptLogger\").info(\"Row {}: Start\u003d{}, End\u003d{}\".format(\n                row[\"ID\"], start_date_time, finish_date_time))\n            \n            # Initialize with None\n            start_date_output \u003d None\n            end_date_output \u003d None\n            \n            # Process StartDateTime - create native Ignition timestamp\n            if start_date_time is not None:\n                try:\n                    # Convert to milliseconds first\n                    start_millis \u003d system.date.toMillis(start_date_time)\n                    \n                    # Create native Ignition timestamp object\n                    start_date_output \u003d system.date.fromMillis(start_millis)\n                    \n                    system.util.getLogger(\"ScriptLogger\").info(\"StartDate converted: {} -\u003e {}\".format(start_millis, start_date_output))\n                    \n                except Exception as e:\n                    system.util.getLogger(\"ScriptLogger\").error(\"StartDate conversion failed: {}\".format(str(e)))\n                    # Try alternative method\n                    try:\n                        start_millis \u003d start_date_time.getTime()\n                        start_date_output \u003d system.date.fromMillis(start_millis)\n                        system.util.getLogger(\"ScriptLogger\").info(\"StartDate alternative method worked: {} -\u003e {}\".format(start_millis, start_date_output))\n                    except Exception as e2:\n                        system.util.getLogger(\"ScriptLogger\").error(\"StartDate alternative also failed: {}\".format(str(e2)))\n            \n            # Process FinishDateTime - create native Ignition timestamp\n            if finish_date_time is not None:\n                try:\n                    # Convert to milliseconds first\n                    end_millis \u003d system.date.toMillis(finish_date_time)\n                    \n                    # Create native Ignition timestamp object\n                    end_date_output \u003d system.date.fromMillis(end_millis)\n                    \n                    system.util.getLogger(\"ScriptLogger\").info(\"EndDate converted: {} -\u003e {}\".format(end_millis, end_date_output))\n                    \n                except Exception as e:\n                    system.util.getLogger(\"ScriptLogger\").error(\"EndDate conversion failed: {}\".format(str(e)))\n                    # Try alternative method\n                    try:\n                        end_millis \u003d finish_date_time.getTime()\n                        end_date_output \u003d system.date.fromMillis(end_millis)\n                        system.util.getLogger(\"ScriptLogger\").info(\"EndDate alternative method worked: {} -\u003e {}\".format(end_millis, end_date_output))\n                    except Exception as e2:\n                        system.util.getLogger(\"ScriptLogger\").error(\"EndDate alternative also failed: {}\".format(str(e2)))\n            \n            # Build the result row\n            row_result \u003d {\n                \"itemId\": \"\",\n                \"eventId\": \"\",\n                \"startDate\": start_date_output,\n                \"endDate\": end_date_output,\n                \"label\": \"Scheduled Event\",\n                \"leadTime\": 0,\n                \"leadStyle\": {\"classes\": \"\"},\n                \"percentDone\": 0,\n                \"style\": {\"classes\": \"\"}\n            }\n            \n            # Log the final structure\n            system.util.getLogger(\"ScriptLogger\").info(\"Final row: startDate\u003d{}, endDate\u003d{}\".format(\n                start_date_output, end_date_output))\n            \n            result.append(row_result)\n        \n        system.util.getLogger(\"ScriptLogger\").info(\"Returning {} rows\".format(len(result)))\n        return result\n        \n    except Exception as e:\n        system.util.getLogger(\"ScriptLogger\").error(\"Query failed: {}\".format(str(e)))\n        return []",
                      "type": "script"
                    }
