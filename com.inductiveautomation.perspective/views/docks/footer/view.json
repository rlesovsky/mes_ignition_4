{
  "custom": {},
  "params": {},
  "props": {
    "defaultSize": {
      "height": 29
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Company"
            },
            "position": {
              "grow": 1
            },
            "props": {
              "style": {
                "classes": "labels/color_normal labels/font labels/size_normal"
              },
              "text": "TAS"
            },
            "type": "ia.display.label"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "Icon"
                },
                "position": {
                  "basis": "18px",
                  "shrink": 0
                },
                "props": {
                  "color": "--neutral-70",
                  "path": "material/brightness_medium"
                },
                "type": "ia.display.icon"
              }
            ],
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "script": "\tif self.session.props.theme \u003d\u003d \u0027light\u0027:\n\t\tself.session.props.theme \u003d \u0027dark\u0027\n\telse:\n\t\tself.session.props.theme \u003d \u0027light\u0027"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "DarkLightMode",
              "tooltip": {
                "enabled": true,
                "text": "LightDark"
              }
            },
            "position": {
              "basis": "60px",
              "shrink": 0
            },
            "props": {
              "justify": "center",
              "style": {
                "cursor": "pointer"
              }
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "left"
        },
        "position": {
          "basis": "86px",
          "shrink": 0
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "middle"
        },
        "position": {
          "grow": 1
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "fallbackDelay": 2.5,
                "mode": "direct",
                "tagPath": "[System]Gateway/CurrentDateTime"
              },
              "transforms": [
                {
                  "formatType": "datetime",
                  "formatValue": {
                    "date": "short",
                    "time": "short"
                  },
                  "type": "format"
                }
              ],
              "type": "tag"
            }
          }
        },
        "props": {
          "style": {
            "classes": "labels/color_normal labels/font labels/size_normal",
            "textAlign": "center"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "right"
        },
        "position": {
          "basis": "100px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "fallbackDelay": 2.5,
                "mode": "direct",
                "tagPath": "[System]Gateway/Redundancy/Role"
              },
              "type": "tag"
            }
          }
        },
        "props": {
          "style": {
            "classes": "labels/color_normal labels/font labels/size_normal",
            "textAlign": "right"
          }
        },
        "type": "ia.display.label"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "alignItems": "center",
      "justify": "space-between",
      "style": {
        "backgroundColor": "#21262d",
        "borderTopColor": "black",
        "borderTopStyle": "none",
        "borderTopWidth": "1px",
        "overflow": "hidden",
        "paddingLeft": "10px",
        "paddingRight": "10px"
      }
    },
    "type": "ia.container.flex"
  }
}