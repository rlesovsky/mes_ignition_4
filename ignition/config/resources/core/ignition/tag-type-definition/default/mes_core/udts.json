      {
        "valueSource": "memory",
        "dataType": "Boolean",
        "name": "Enable",
        "value": true,
        "tagType": "AtomicTag"
      },
      {
        "valueSource": "expr",
        "eventScripts": [
          {
            "eventid": "valueChanged",
            "script": "\n\tdb \u003d \u0027mes_core\u0027\n\tenable \u003d system.tag.readBlocking([\"[.]Enable\"])[0].value\n\t\n\tif not initialChange:\n\t\tstamp \u003d system.date.now()\n\t\tsystem.tag.writeBlocking([\"[.]State Start Time\"], [stamp])\n\t\t\n\t\tif enable \u003d\u003d 1:\n\t\t\tlineID \u003d system.tag.readBlocking([\"[.]LineID\"])[0].value\n\t\t\trunID \u003d system.tag.readBlocking([\"[.]RunID\"])[0].value\n\t\t\treasonCode \u003d currentValue.value if currentValue.quality.isGood() else 0\n\t\t\t\n\t\t\t# Get state reason info from database\n\t\t\treasonQuery \u003d \u0027SELECT id, reasonname FROM statereason WHERE reasoncode \u003d ? AND parentid \u003d ?\u0027\n\t\t\tdata \u003d system.db.runPrepQuery(reasonQuery, [reasonCode, lineID], db)\n\t\t\t\n\t\t\tfor row in data:\n\t\t\t\treasonID \u003d row[0]\n\t\t\t\treasonName \u003d row[1]\n\t\t\t\t\n\t\t\t\t# End the previous state (set EndDateTime where it\u0027s NULL)\n\t\t\t\tendQuery \u003d \u0027UPDATE statehistory SET enddatetime \u003d ? WHERE lineid \u003d ? AND enddatetime IS NULL\u0027\n\t\t\t\tsystem.db.runPrepUpdate(endQuery, [stamp, lineID], db)\n\t\t\t\t\n\t\t\t\t# Insert new state record\n\t\t\t\tinsertQuery \u003d \u0027\u0027\u0027INSERT INTO statehistory (statereasonid, runid, reasonname, lineid, reasoncode, startdatetime)\n\t\t\t\t\tVALUES (?,?,?,?,?,?)\u0027\u0027\u0027\n\t\t\t\tsystem.db.runPrepUpdate(insertQuery, [reasonID, runID, reasonName, lineID, reasonCode, stamp], db)\n\t\n"
          }
        ],
        "expression": "{[.]../State}",
        "name": "Line State",
        "tagType": "AtomicTag"
