      {
        "valueSource": "expr",
        "eventScripts": [
          {
            "eventid": "valueChanged",
            "script": "\n\tenable \u003d system.tag.readBlocking([\"[.]Enable\"])[0].value\n\t\n\tif enable \u003d\u003d 1 and not initialChange:\n\t\tlastCountTagPath \u003d \"[.]LastCount\"\n\t\t\n\t\t# Treat a current value of 0 as a reset/rollover event\n\t\tif currentValue.value \u003d\u003d 0:\n\t\t\t# Make sure the last count doesn\u0027t remember the drop and subtract on rise\n\t\t\tsystem.tag.writeBlocking([lastCountTagPath], [0])\n\t\telse:\n\t\t\tdb \u003d \u0027mes_core\u0027\n\t\t\tstamp \u003d system.date.now()\n\t\t\t\n\t\t\tcurrentCount \u003d currentValue.value\n\t\t\tlastCount \u003d system.tag.readBlocking([\"[.]LastCount\"])[0].value\n\t\t\ttagID \u003d system.tag.readBlocking([\"[.]TagID\"])[0].value\n\t\t\trunID \u003d system.tag.readBlocking([\"[.]RunID\"])[0].value\n\t\t\tcountTypeID \u003d system.tag.readBlocking([\"[.]CountTypeID\"])[0].value\n\t\t\t\n\t\t\tcountDelta \u003d currentCount - lastCount\n\t\t\t\n\t\t\t# PostgreSQL query with lowercase columns and quoted \"TimeStamp\"\n\t\t\tquery \u003d \u0027INSERT INTO counthistory (tagid, runid, counttypeid, count, \"TimeStamp\") VALUES (?,?,?,?,?)\u0027\n\t\t\t\n\t\t\tsystem.db.runPrepUpdate(query, [tagID, runID, countTypeID, countDelta, stamp], db)\n\t\t\t\n\t\t\tsystem.tag.writeBlocking([lastCountTagPath], [currentCount])"
          }
        ],
        "name": "Count",
        "tagType": "AtomicTag"
      },
      {
        "valueSource": "memory",
        "name": "CountTypeID",
        "tagType": "AtomicTag"
      },
