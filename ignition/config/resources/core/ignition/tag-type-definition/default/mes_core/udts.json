        "expression": "if(\r\n  isNull({[.]OEE Availability}) || \r\n  isNull({[.]OEE Performance}) || \r\n  isNull({[.]OEE Quality}),\r\n  0,\r\n  {[.]OEE Availability} * {[.]OEE Performance} * {[.]OEE Quality}\r\n)",
