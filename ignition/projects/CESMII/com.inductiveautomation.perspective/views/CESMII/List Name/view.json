{
  "custom": {},
  "params": {
    "index": 0,
    "name": "Test"
  },
  "propConfig": {
    "params.index": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.name": {
      "paramDirection": "inout",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 30,
      "width": 300
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Label"
        },
        "position": {
          "basis": "120px",
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "expression": "\"Instance #\" + ({view.params.index} + 1)"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "marginRight": "10px"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "TextField"
        },
        "position": {
          "grow": 1
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "bidirectional": true,
                "path": "view.params.name"
              },
              "type": "property"
            }
          }
        },
        "type": "ia.input.text-field"
      }
    ],
    "meta": {
      "name": "root"
    },
    "type": "ia.container.flex"
  }
}