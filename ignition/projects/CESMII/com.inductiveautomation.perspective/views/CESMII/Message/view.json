{
  "custom": {},
  "params": {
    "color": "",
    "icon": "error_outline",
    "message": "Here is my message",
    "title": "Download Error"
  },
  "propConfig": {
    "params.color": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.icon": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.message": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.title": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 270,
      "width": 410
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Icon"
            },
            "position": {
              "basis": "30px",
              "shrink": 0
            },
            "propConfig": {
              "props.color": {
                "binding": {
                  "config": {
                    "path": "view.params.color"
                  },
                  "type": "property"
                }
              },
              "props.path": {
                "binding": {
                  "config": {
                    "expression": "\"material/\" + {view.params.icon}"
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "marginRight": "5px"
              }
            },
            "type": "ia.display.icon"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "Label"
                },
                "position": {
                  "shrink": 0
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "path": "view.params.title"
                      },
                      "type": "property"
                    }
                  }
                },
                "props": {
                  "style": {
                    "fontSize": "20px",
                    "fontWeight": "bold"
                  }
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "FlexContainer"
            },
            "position": {
              "grow": 1
            },
            "propConfig": {
              "props.style.color": {
                "binding": {
                  "config": {
                    "path": "view.params.color"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "direction": "column",
              "justify": "center"
            },
            "type": "ia.container.flex"
          },
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "draggable": true,
                    "id": "message",
                    "modal": false,
                    "overlayDismiss": false,
                    "resizable": true,
                    "showCloseIcon": true,
                    "type": "close",
                    "viewPath": "",
                    "viewportBound": false
                  },
                  "scope": "C",
                  "type": "popup"
                }
              }
            },
            "meta": {
              "name": "Icon_0"
            },
            "position": {
              "basis": "30px",
              "shrink": 0
            },
            "props": {
              "path": "material/close",
              "style": {
                "cursor": "pointer"
              }
            },
            "type": "ia.display.icon"
          }
        ],
        "meta": {
          "name": "FlexContainer"
        },
        "position": {
          "basis": "60px",
          "shrink": 0
        },
        "props": {
          "style": {
            "backgroundColor": "rgba(0,0,0,.03)",
            "borderBottomColor": "#ced4da",
            "borderBottomStyle": "solid",
            "borderBottomWidth": "1px",
            "padding": "10px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": {
              "name": "Label_0"
            },
            "position": {
              "grow": 1
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.message"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "alignVertical": "top",
              "style": {
                "fontSize": "16px"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "FlexContainer_0"
        },
        "position": {
          "grow": 1
        },
        "props": {
          "style": {
            "backgroundColor": "#FFFFFF",
            "padding": "10px"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "events": {
              "component": {
                "onActionPerformed": {
                  "config": {
                    "draggable": true,
                    "id": "message",
                    "modal": false,
                    "overlayDismiss": false,
                    "resizable": true,
                    "showCloseIcon": true,
                    "type": "close",
                    "viewPath": "",
                    "viewportBound": false
                  },
                  "scope": "C",
                  "type": "popup"
                }
              }
            },
            "meta": {
              "name": "Close"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "marginLeft": "10px",
                "paddingLeft": "6px",
                "paddingRight": "6px"
              },
              "text": "Close"
            },
            "type": "ia.input.button"
          }
        ],
        "meta": {
          "name": "FlexContainer_1"
        },
        "position": {
          "basis": "60px",
          "shrink": 0
        },
        "props": {
          "justify": "flex-end",
          "style": {
            "backgroundColor": "rgba(0,0,0,.03)",
            "borderTopColor": "#ced4da",
            "borderTopStyle": "solid",
            "borderTopWidth": "1px",
            "padding": "10px"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column"
    },
    "type": "ia.container.flex"
  }
}