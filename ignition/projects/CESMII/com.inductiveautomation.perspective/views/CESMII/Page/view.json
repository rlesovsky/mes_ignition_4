{
  "custom": {},
  "params": {
    "ellipsis": false,
    "page": 1,
    "selected": true
  },
  "propConfig": {
    "params.ellipsis": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.page": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.selected": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 36,
      "width": 50
    }
  },
  "root": {
    "children": [
      {
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\tif not self.view.params.selected:\n\t\tsystem.perspective.sendMessage(\"paginator\", {\"page\":self.view.params.page})"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "Label"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "expression": "!{view.params.ellipsis}"
              },
              "type": "expr"
            }
          },
          "props.style.backgroundColor": {
            "binding": {
              "config": {
                "expression": "if({view.params.selected}, \"#007bff\", \"\")"
              },
              "type": "expr"
            }
          },
          "props.style.color": {
            "binding": {
              "config": {
                "expression": "if({view.params.selected}, \"#FFFFFF\", \"\")"
              },
              "type": "expr"
            }
          },
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.page"
              },
              "transforms": [
                {
                  "formatType": "numeric",
                  "formatValue": "integer",
                  "type": "format"
                }
              ],
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "borderRightColor": "#ced4da",
            "borderRightStyle": "solid",
            "borderRightWidth": "1px",
            "cursor": "pointer",
            "paddingLeft": "10px",
            "paddingRight": "10px"
          }
        },
        "type": "ia.display.label"
      },
      {
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\tsystem.perspective.sendMessage(\"paginator\", {\"page\":self.view.params.page})"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "Label_0"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "path": "view.params.ellipsis"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "borderRightColor": "#ced4da",
            "borderRightStyle": "solid",
            "borderRightWidth": "1px",
            "cursor": "pointer",
            "paddingLeft": "10px",
            "paddingRight": "10px"
          },
          "text": "..."
        },
        "type": "ia.display.label"
      }
    ],
    "meta": {
      "name": "root"
    },
    "type": "ia.container.flex"
  }
}