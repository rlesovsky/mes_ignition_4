          "script": "\ttags \u003d system.util.jsonDecode(self.view.params.tags)\n\t\n\tdef validate(parent):\n\t\tret \u003d True\n\t\tif \"tags\" in parent:\n\t\t\tfor tag in parent[\"tags\"]:\n\t\t\t\tif \"list\" in tag and not tag[\"list\"][\"complete\"]:\n\t\t\t\t\tret \u003d False\n\t\t\t\telse:\n\t\t\t\t\tret \u003d validate(tag)\n\t\t\t\t\tif not ret:\n\t\t\t\t\t\tbreak\n\t\t\t\t\t\n\t\treturn ret\n\t\n\tret \u003d ignoreAttn or validate(tags)\n\tif not ret:\n\t\tCESMII.Converter.showErrorMessage(\"Missing Data\", \"Please fix all UDT instances in red.\")\n\telse:\n\t\ttags \u003d self.updateTags(tags)\n\t\t\n\treturn (ret, tags)"
        },
        {
          "name": "updateTags",
          "params": [
            "tags"
          ],
          "script": "\tdef update(parent):\n\t\tif \"tags\" in parent:\n\t\t\ttagsToAdd \u003d []\n\t\t\tfor tag in parent[\"tags\"]:\n\t\t\t\tif \"list\" in tag and tag[\"list\"][\"complete\"]:\n\t\t\t\t\tnames \u003d tag[\"list\"][\"names\"]\n\t\t\t\t\t\n\t\t\t\t\tif len(names) \u003e 0:\n\t\t\t\t\t\toldName \u003d tag[\"name\"]\n\t\t\t\t\t\ttag[\"name\"] \u003d names[0]\n\n\t\t\t\t\t\tfor i in range(1, len(names)):\n\t\t\t\t\t\t\tnewTag \u003d system.util.jsonDecode(system.util.jsonEncode(tag))\n\t\t\t\t\t\t\tnewTag[\"name\"] \u003d names[i]\n\t\t\t\t\t\t\tif \"parameters\" in newTag:\n\t\t\t\t\t\t\t\tidx \u003d newTag[\"parameters\"][\"UAPrefix\"][\"value\"][\"binding\"].rindex(oldName)\n\t\t\t\t\t\t\t\tnewTag[\"parameters\"][\"UAPrefix\"][\"value\"][\"binding\"] \u003d \"%s%s\" % (newTag[\"parameters\"][\"UAPrefix\"][\"value\"][\"binding\"][:idx], names[i])\n\t\t\t\t\t\t\tnewTag.pop(\"list\")\n\t\t\t\t\t\t\ttagsToAdd.append(newTag)\n\t\t\t\t\t\t\n\t\t\t\t\t\tif \"parameters\" in tag:\n\t\t\t\t\t\t\tidx \u003d tag[\"parameters\"][\"UAPrefix\"][\"value\"][\"binding\"].rindex(oldName)\n\t\t\t\t\t\t\ttag[\"parameters\"][\"UAPrefix\"][\"value\"][\"binding\"] \u003d \"%s%s\" % (tag[\"parameters\"][\"UAPrefix\"][\"value\"][\"binding\"][:idx], names[0])\n\t\t\t\t\t\t\t\n\t\t\t\t\t\ttag.pop(\"list\")\n\t\t\t\telse:\n\t\t\t\t\tupdate(tag)\n\t\t\t\n\t\t\tparent[\"tags\"].extend(tagsToAdd)\n\t\n\tupdate(tags)\n\treturn tags"
        }
