{
  "custom": {},
  "params": {
    "icon": "home",
    "text": "Home"
  },
  "propConfig": {
    "params.icon": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.text": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 56,
      "width": 600
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Icon"
        },
        "position": {
          "basis": "24px",
          "shrink": 0
        },
        "propConfig": {
          "props.path": {
            "binding": {
              "config": {
                "expression": "\"material/\" + {view.params.icon}"
              },
              "type": "expr"
            },
            "persistent": false
          }
        },
        "props": {
          "style": {
            "classes": "",
            "fill": "var(--neutral-90)",
            "marginLeft": "10px"
          }
        },
        "type": "ia.display.icon"
      },
      {
        "meta": {
          "hasDelegate": true,
          "name": "Label"
        },
        "position": {
          "grow": 1
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.text"
              },
              "type": "property"
            },
            "persistent": false
          }
        },
        "props": {
          "style": {
            "color": "var(--neutral-90)",
            "fill": "var(--neutral-90)",
            "fontSize": "16px",
            "fontWeight": "bold",
            "lineHeight": "19px",
            "marginLeft": "6px"
          }
        },
        "type": "ia.display.label"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "style": {
        "backgroundColor": "var(--neutral-30)",
        "borderBottomColor": "var(--neutral-60)",
        "borderBottomStyle": "solid",
        "borderBottomWidth": "1px",
        "borderTopColor": "var(--neutral-60)",
        "borderTopStyle": "solid",
        "borderTopWidth": "1px"
      }
    },
    "type": "ia.container.flex"
  }
}