                  "transforms": [
                    {
                      "code": "\n\tlogger \u003d system.util.getLogger(\"WasteApexChart\")\n\t\n\ttry:\n\t\trunID \u003d self.view.custom.runID if hasattr(self.view.custom, \u0027runID\u0027) else None\n\t\t\n\t\tif runID is None:\n\t\t\treturn [{\"name\": \"Waste Count\", \"data\": []}]\n\t\t\n\texcept Exception as e:\n\t\tlogger.error(\"Parameter error: \" + str(e))\n\t\treturn [{\"name\": \"Waste Count\", \"data\": []}]\n\t\n\ttry:\n\t\tsql_query \u003d \"\"\"\n\t\tSELECT EXTRACT(HOUR FROM \"TimeStamp\") as Hour, \n\t\t       SUM(count) as Actual\n\t\tFROM counthistory\n\t\tWHERE counttypeid \u003d 3\n\t\t  AND runid \u003d ?\n\t\t  AND count \u003e 0\n\t\tGROUP BY DATE(\"TimeStamp\"), EXTRACT(HOUR FROM \"TimeStamp\")\n\t\tORDER BY DATE(\"TimeStamp\") DESC, EXTRACT(HOUR FROM \"TimeStamp\") DESC\n\t\tLIMIT 8\n\t\t\"\"\"\n\t\t\n\t\tdataset \u003d system.db.runPrepQuery(sql_query, [runID], \u0027mes_core\u0027)\n\t\tlogger.info(\"Query executed, found {} rows for runID {}\".format(dataset.getRowCount(), runID))\n\t\t\n\t\tdata \u003d []\n\t\tfor row in range(dataset.getRowCount()):\n\t\t\thour \u003d dataset.getValueAt(row, \"Hour\")\n\t\t\tactual \u003d dataset.getValueAt(row, \"Actual\")\n\t\t\t\n\t\t\tif hour is not None and actual is not None:\n\t\t\t\tdata.append({\n\t\t\t\t\t\"x\": \"{}:00\".format(int(hour)),\n\t\t\t\t\t\"y\": int(actual)\n\t\t\t\t})\n\t\t\t\tlogger.info(\"Added: Hour {} \u003d {} units\".format(hour, actual))\n\t\t\n\t\tdata.reverse()\n\t\t\n\t\treturn [{\"name\": \"Waste Count\", \"data\": data}]\n\t\t\n\texcept Exception as e:\n\t\tlogger.error(\"Query error: \" + str(e))\n\t\treturn [{\"name\": \"Waste Count\", \"data\": []}]",
                      "type": "script"
