        "propConfig": {
          "props.data": {
            "binding": {
              "config": {
                "fallbackDelay": 2.5,
                "mode": "expression",
                "tagPath": "now()"
              },
              "transforms": [
                {
                  "code": "\n\tdbName \u003d \"mes_core\"\n\tlogger \u003d system.util.getLogger(\"ScriptLogger\")\n\t\n\tquery \u003d \"\"\"\n\t\tSELECT\n\t\t\ts.id AS \"ID\",\n\t\t\ts.reasonname AS \"ReasonName\",\n\t\t\ts.reasoncode AS \"ReasonCode\",\n\t\t\ts.startdatetime AS \"StartDateTime\",\n\t\t\ts.enddatetime AS \"EndDateTime\",\n\t\t\tEXTRACT(EPOCH FROM (s.enddatetime - s.startdatetime)) AS \"Total in Seconds\",\n\t\t\ts.note AS \"Note\"\n\t\tFROM statehistory s\n\t\tLEFT JOIN statereason st ON s.statereasonid \u003d st.id\n\t\tWHERE (\n\t\t\tst.recorddowntime \u003d true\n\t\t\tAND s.startdatetime \u003e\u003d ?\n\t\t\tAND s.enddatetime \u003c CURRENT_TIMESTAMP\n\t\t\tAND s.enddatetime \u003e s.startdatetime\n\t\t\tAND s.lineid \u003d ?\n\t\t)\n\t\tOR (\n\t\t\tst.recorddowntime \u003d true\n\t\t\tAND s.lineid \u003d ?\n\t\t\tAND s.enddatetime IS NULL\n\t\t)\n\t\tORDER BY s.startdatetime DESC\n\t\"\"\"\n\t\n\ttry:\n\t\t# Get lineID from view params or tag\n\t\tlineID \u003d 1\n\t\tlogger.info(\"lineID: {}\".format(lineID))\n\t\t\n\t\t# Read startTime tag with quality check\n\t\ttagPath \u003d \"[default]Enterprise/Site/Area/Line 1/Line/Start Time\"\n\t\tstartTimeResult \u003d system.tag.readBlocking([tagPath])[0]\n\t\t\n\t\tif not startTimeResult.quality.isGood():\n\t\t\tlogger.error(\"Start Time tag quality is bad: {}\".format(startTimeResult.quality))\n\t\t\traise ValueError(\"Start Time tag quality is not good\")\n\t\t\n\t\tstartTime \u003d startTimeResult.value\n\t\tlogger.info(\"startTime value: {}\".format(startTime))\n\t\tlogger.info(\"startTime type: {}\".format(type(startTime)))\n\t\t\n\t\t# Check if startTime is null\n\t\tif startTime is None:\n\t\t\tlogger.error(\"Start Time tag value is None\")\n\t\t\traise ValueError(\"Start Time is null\")\n\t\t\n\t\tparams \u003d [startTime, lineID, lineID]\n\t\tlogger.info(\"Query params: {}\".format(params))\n\t\t\n\t\t# Execute the query\n\t\tdata \u003d system.db.runPrepQuery(query, params, dbName)\n\t\tlogger.info(\"Query returned {} rows\".format(data.getRowCount()))\n\t\t\n\t\tcolumn_names \u003d data.getColumnNames()\n\t\tjson_data \u003d system.dataset.toPyDataSet(data)\n\t\t\n\t\tif data.getRowCount() \u003e 0:\n\t\t\tresult \u003d [\n\t\t\t\t{col: row[col] for col in column_names}\n\t\t\t\tfor row in json_data\n\t\t\t]\n\t\telse:\n\t\t\tresult \u003d [\n\t\t\t\t{col: None for col in column_names}\n\t\t\t]\n\t\t\n\t\treturn result\n\t\n\texcept Exception as e:\n\t\tlogger.error(\"Query failed: {}\".format(str(e)))\n\t\treturn [\n\t\t\t{\n\t\t\t\t\u0027ID\u0027: None,\n\t\t\t\t\u0027ReasonName\u0027: None,\n\t\t\t\t\u0027ReasonCode\u0027: None,\n\t\t\t\t\u0027StartDateTime\u0027: None,\n\t\t\t\t\u0027EndDateTime\u0027: None,\n\t\t\t\t\u0027Total in Seconds\u0027: None,\n\t\t\t\t\u0027Note\u0027: None\n\t\t\t}\n\t\t]",
                  "type": "script"
                }
              ],
              "type": "tag"
            }
          }
        },
