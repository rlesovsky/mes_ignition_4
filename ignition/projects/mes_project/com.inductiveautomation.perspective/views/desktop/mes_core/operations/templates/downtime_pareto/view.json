              "transforms": [
                {
                  "code": "\n\tlogger \u003d system.util.getLogger(\"DowntimeChart\")\n\t\n\ttry:\n\t\tstartDate \u003d self.view.custom.startDate\n\t\tendTime \u003d self.view.custom.endTime\n\t\tlineID \u003d 1\n\t\t\n\t\tif startDate is None or endTime is None:\n\t\t\treturn {\"downtime_data\": []}\n\t\t\t\n\texcept Exception as e:\n\t\tlogger.error(\"Parameter error: \" + str(e))\n\t\treturn {\"downtime_data\": []}\n\t\n\ttry:\n\t\tsql_query \u003d \"\"\"\n\t\tSELECT s.reasonname AS \\\"Reason\\\", \n\t\t       SUM(EXTRACT(EPOCH FROM (sh.enddatetime - sh.startdatetime)))/60 AS \\\"DowntimeMinutes\\\"\n\t\tFROM statehistory sh\n\t\tLEFT JOIN statereason s ON sh.statereasonid \u003d s.id\n\t\tWHERE s.recorddowntime \u003d true\n\t\t  AND sh.startdatetime \u003e ?\n\t\t  AND sh.enddatetime \u003c ?\n\t\t  AND s.parentid \u003d ?\n\t\tGROUP BY s.reasonname\n\t\tORDER BY 2 DESC\n\t\tLIMIT 5\n\t\t\"\"\"\n\t\t\n\t\tdataset \u003d system.db.runPrepQuery(sql_query, [startDate, endTime, lineID], \u0027mes_core\u0027)\n\t\t\n\t\tresult \u003d []\n\t\tfor row in range(dataset.getRowCount()):\n\t\t\treason \u003d dataset.getValueAt(row, \"Reason\")\n\t\t\tminutes \u003d dataset.getValueAt(row, \"DowntimeMinutes\")\n\t\t\t\n\t\t\tif reason and minutes is not None:\n\t\t\t\tresult.append({\n\t\t\t\t\t\"Reason\": str(reason),\n\t\t\t\t\t\"Downtime Minutes\": float(minutes)\n\t\t\t\t})\n\t\t\n\t\treturn {\"downtime_data\": result}\n\t\t\n\texcept Exception as e:\n\t\tlogger.error(\"Query error: \" + str(e))\n\t\treturn {\"downtime_data\": []}",
                  "type": "script"
                }
              ],
              "type": "expr"
            }
          }
