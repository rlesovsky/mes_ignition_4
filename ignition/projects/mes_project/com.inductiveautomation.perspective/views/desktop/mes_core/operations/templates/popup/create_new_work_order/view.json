                        "script": "\ttimestamp \u003d system.date.now()\n\ttimestamp \u003d system.date.setTime(timestamp, system.date.getHour24(timestamp), system.date.getMinute(timestamp), system.date.getSecond(timestamp))\n\n\troot \u003d self.parent.parent\n\tcontent \u003d root.getChild(\u0027content\u0027)\n\ttable \u003d content.getChild(\u0027product_section\u0027).getChild(\u0027table\u0027)\n\tquantity_section \u003d content.getChild(\u0027quantity_section\u0027)\n\n\tselected_row \u003d table.props.selection.selectedRow\n\n\tif selected_row \u003d\u003d -1:\n\t\tsystem.perspective.print(\"No product selected.\")\n\t\treturn\n\n\tprod_code \u003d table.props.selection.data[0].ProductCode\n\tproduct_code_id \u003d table.props.selection.data[0].ID\n\tquantity \u003d quantity_section.getChild(\u0027quantity\u0027).getChild(\u0027NumericEntryField\u0027).props.value\n\n\tdb \u003d \u0027mes_core\u0027\n\n\ttimestamp_str \u003d system.date.format(timestamp, \"yyyy-MM-dd_HH-mm-ss\")\n\tprod_code_clean \u003d prod_code.replace(\" \", \"_\")\n\twork_order \u003d \"WO__\" + prod_code_clean + \"_\" + timestamp_str\n\n\tquery \u003d \u0027\u0027\u0027INSERT INTO workorder (workorder, quantity, closed, hide, \"TimeStamp\", productcodeid, productcode)\n\t\tVALUES (?, ?, ?, ?, ?, ?, ?)\u0027\u0027\u0027\n\n\ttry:\n\t\tresult \u003d system.db.runPrepUpdate(query, [work_order, quantity, False, False, timestamp, product_code_id, prod_code], db)\n\t\tif result \u003d\u003d 1:\n\t\t\tsystem.perspective.closePopup(\u0027\u0027)\n\texcept Exception as e:\n\t\tsystem.util.getLogger(\u0027ScriptLogger\u0027).error(\u0027Insert failed: {}\u0027.format(str(e)))"
