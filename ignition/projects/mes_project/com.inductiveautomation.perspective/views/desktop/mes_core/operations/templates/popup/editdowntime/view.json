                },
                "props": {
                  "style": {
                    "color": "#4A6080",
                    "fontFamily": "\u0027IBM Plex Sans\u0027, -apple-system, BlinkMacSystemFont, \u0027Segoe UI\u0027, Arial, sans-serif",
                    "fontSize": 10,
                    "fontWeight": 600,
                    "letterSpacing": "0.07em",
                    "textTransform": "uppercase"
                  },
                  "text": "REASON"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "reasonDropdown"
                },
                "position": {
                  "basis": "220px",
                  "shrink": 0
                },
                "propConfig": {
                  "props.options": {
                    "binding": {
                      "config": {
                        "fallbackDelay": 2.5,
                        "mode": "expression",
                        "tagPath": "now()"
                      },
                      "transforms": [
                        {
                          "code": "\tdbName \u003d \u0027mes_core\u0027\n\tlineId \u003d 1\n\n\tquery \u003d \"\"\"\n\t\tSELECT id, reasoncode, reasonname\n\t\tFROM statereason\n\t\tWHERE parentid \u003d ?\n\t\t\tAND operatorselectable \u003d true\n\t\tORDER BY reasonname\n\t\"\"\"\n\n\ttry:\n\t\tdata \u003d system.db.runPrepQuery(query, [lineId], dbName)\n\t\tresult \u003d []\n\t\tfor row in system.dataset.toPyDataSet(data):\n\t\t\tresult.append({\n\t\t\t\t\u0027label\u0027: row[\u0027reasonname\u0027],\n\t\t\t\t\u0027value\u0027: row[\u0027id\u0027]\n\t\t\t})\n\t\treturn result\n\texcept Exception as e:\n\t\tlogger \u003d system.util.getLogger(\u0027EditDowntime\u0027)\n\t\tlogger.error(\u0027Failed to load reasons: \u0027 + str(e))\n\t\treturn []",
                          "type": "script"
                        }
                      ],
                      "type": "tag"
                    }
                  }
                },
                "props": {
                  "style": {
                    "backgroundColor": "#0D1117",
                    "border": "1px solid #223044",
                    "borderRadius": 4,
                    "color": "#E2E8F0",
                    "fontFamily": "\u0027IBM Plex Sans\u0027, -apple-system, BlinkMacSystemFont, \u0027Segoe UI\u0027, Arial, sans-serif",
                    "fontSize": 12
                  },
                  "value": 4
                },
                "type": "ia.input.dropdown"
              },
              {
                "meta": {
                  "name": "noteLabel"
                },
                "position": {
                  "basis": "40px",
                  "shrink": 0
                },
                "props": {
                  "style": {
                    "color": "#4A6080",
                    "fontFamily": "\u0027IBM Plex Sans\u0027, -apple-system, BlinkMacSystemFont, \u0027Segoe UI\u0027, Arial, sans-serif",
                    "fontSize": 10,
                    "fontWeight": 600,
                    "letterSpacing": "0.07em",
                    "marginLeft": 4,
                    "textTransform": "uppercase"
                  },
                  "text": "NOTE"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "noteInput"
                },
                "position": {
                  "basis": "100px",
                  "grow": 1
                },
                "props": {
                  "placeholder": "Add note...",
                  "style": {
                    "backgroundColor": "#0D1117",
                    "border": "1px solid #223044",
                    "borderRadius": 4,
                    "color": "#E2E8F0",
                    "fontFamily": "\u0027IBM Plex Sans\u0027, -apple-system, BlinkMacSystemFont, \u0027Segoe UI\u0027, Arial, sans-serif",
                    "fontSize": 12
                  }
                },
                "type": "ia.input.text-field"
              },
              {
                "events": {
                  "component": {
                    "onActionPerformed": {
                      "config": {
                        "script": "\tlogger \u003d system.util.getLogger(\u0027EditDowntime\u0027)\n\n\troot \u003d self.parent.parent.parent\n\teditPanel \u003d root.getChild(\u0027editPanel\u0027)\n\teditRow \u003d editPanel.getChild(\u0027editFieldsRow\u0027)\n\n\t# Get the selected event ID\n\tselectedId \u003d root.custom.selectedEventId\n\tif selectedId is None:\n\t\treturn\n\n\t# Get the new values from the edit fields\n\treasonDropdown \u003d editRow.getChild(\u0027reasonDropdown\u0027)\n\tnoteInput \u003d editRow.getChild(\u0027noteInput\u0027)\n\n\tnewReasonId \u003d reasonDropdown.props.value\n\tnewReasonLabel \u003d \u0027\u0027\n\tfor opt in reasonDropdown.props.options:\n\t\tif opt[\u0027value\u0027] \u003d\u003d newReasonId:\n\t\t\tnewReasonLabel \u003d opt[\u0027label\u0027]\n\t\t\tbreak\n\n\tnewNote \u003d noteInput.props.text if noteInput.props.text else \u0027\u0027\n\n\t# Get the reason code from the database\n\tdbName \u003d \u0027mes_core\u0027\n\ttry:\n\t\tcodeQuery \u003d \"SELECT reasoncode FROM statereason WHERE id \u003d ?\"\n\t\tcodeResult \u003d system.db.runPrepQuery(codeQuery, [newReasonId], dbName)\n\t\tnewReasonCode \u003d codeResult.getValueAt(0, 0) if codeResult.getRowCount() \u003e 0 else 0\n\texcept:\n\t\tnewReasonCode \u003d 0\n\n\t# Build the change entry\n\tchangeEntry \u003d {\n\t\t\u0027statehistoryId\u0027: selectedId,\n\t\t\u0027statereasonId\u0027: newReasonId,\n\t\t\u0027reasoncode\u0027: newReasonCode,\n\t\t\u0027reasonname\u0027: newReasonLabel,\n\t\t\u0027note\u0027: newNote\n\t}\n\n\t# Update or add to pending changes\n\tpending \u003d list(root.custom.pendingChanges)\n\tfound \u003d False\n\tfor i, entry in enumerate(pending):\n\t\tif entry[\u0027statehistoryId\u0027] \u003d\u003d selectedId:\n\t\t\tpending[i] \u003d changeEntry\n\t\t\tfound \u003d True\n\t\t\tbreak\n\n\tif not found:\n\t\tpending.append(changeEntry)\n\n\troot.custom.pendingChanges \u003d pending\n\n\tlogger.info(\u0027Applied change for event \u0027 + str(selectedId) + \u0027: \u0027 + newReasonLabel)\n\tsystem.perspective.print(\u0027Change applied for event \u0027 + str(selectedId))"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
