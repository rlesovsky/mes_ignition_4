            "code": "\n    logger \u003d system.util.getLogger(\"StringSplitTransform\")\n    \n    if not quality.isGood():\n        return \"\"\n    \n    if not isinstance(value, basestring) or value is None:\n        logger.error(\"Invalid input: {}\".format(value))\n        return \"\"\n        \n    return value.rsplit(\u0027/\u0027, 1)[-1] if \u0027/\u0027 in value else value",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": true
    },
    "params.runID": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.scheduleID": {
