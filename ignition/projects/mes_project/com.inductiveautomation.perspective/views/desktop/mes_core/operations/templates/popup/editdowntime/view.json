      {
        "events": {
          "component": {
            "onSelectionChange": {
              "config": {
                "script": "\troot \u003d self.parent\n\teditPanel \u003d root.getChild(\u0027editPanel\u0027)\n\teditRow \u003d editPanel.getChild(\u0027editFieldsRow\u0027)\n\n\tselData \u003d self.props.selection.data\n\n\tif selData is None or len(selData) \u003d\u003d 0:\n\t\troot.custom.selectedEventId \u003d None\n\t\troot.custom.selectedEditable \u003d False\n\t\treturn\n\n\trow \u003d selData[0]\n\teventId \u003d row[\u0027ID\u0027]\n\teditable \u003d row[\u0027OperatorSelectable\u0027]\n\n\troot.custom.selectedEventId \u003d eventId\n\troot.custom.selectedEditable \u003d editable\n\n\tif editable:\n\t\t# Check if there is a pending change for this event\n\t\tpending \u003d root.custom.pendingChanges\n\t\tpendingEntry \u003d None\n\t\tfor entry in pending:\n\t\t\tif entry[\u0027statehistoryId\u0027] \u003d\u003d eventId:\n\t\t\t\tpendingEntry \u003d entry\n\t\t\t\tbreak\n\n\t\treasonDropdown \u003d editRow.getChild(\u0027reasonDropdown\u0027)\n\t\tnoteInput \u003d editRow.getChild(\u0027noteInput\u0027)\n\n\t\tif pendingEntry:\n\t\t\treasonDropdown.props.value \u003d pendingEntry[\u0027statereasonId\u0027]\n\t\t\tnoteInput.props.text \u003d pendingEntry[\u0027note\u0027]\n\t\telse:\n\t\t\treasonDropdown.props.value \u003d row[\u0027StateReasonId\u0027]\n\t\t\tnoteInput.props.text \u003d row[\u0027Note\u0027] if row[\u0027Note\u0027] else \u0027\u0027"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "downtimeTable"
        },
        "position": {
          "basis": "200px",
          "grow": 1,
          "shrink": 0
        },
        "propConfig": {
          "props.data": {
            "binding": {
              "config": {
                "fallbackDelay": 2.5,
                "mode": "expression",
                "tagPath": "now()"
              },
              "transforms": [
                {
                  "code": "\tdbName \u003d \u0027mes_core\u0027\n\tlogger \u003d system.util.getLogger(\u0027EditDowntime\u0027)\n\n\trunId \u003d self.view.params.runID\n\tlineId \u003d 1\n\n\tquery \u003d \"\"\"\n\t\tSELECT\n\t\t\ts.id AS \"ID\",\n\t\t\ts.statereasonid AS \"StateReasonId\",\n\t\t\ts.reasonname AS \"ReasonName\",\n\t\t\ts.reasoncode AS \"ReasonCode\",\n\t\t\tCASE WHEN st.planneddowntime \u003d true THEN \u0027Planned\u0027 ELSE \u0027Unplanned\u0027 END AS \"Type\",\n\t\t\ts.startdatetime AS \"StartDateTime\",\n\t\t\ts.enddatetime AS \"EndDateTime\",\n\t\t\tCONCAT(\n\t\t\t\tFLOOR(EXTRACT(EPOCH FROM (s.enddatetime - s.startdatetime)) / 60)::TEXT,\n\t\t\t\t\u0027:\u0027,\n\t\t\t\tLPAD(MOD(EXTRACT(EPOCH FROM (s.enddatetime - s.startdatetime))::INTEGER, 60)::TEXT, 2, \u00270\u0027)\n\t\t\t) AS \"Duration\",\n\t\t\tCOALESCE(s.note, \u0027\u0027) AS \"Note\",\n\t\t\tCOALESCE(st.operatorselectable, false) AS \"OperatorSelectable\"\n\t\tFROM statehistory s\n\t\tLEFT JOIN statereason st ON s.statereasonid \u003d st.id\n\t\tWHERE st.recorddowntime \u003d true\n\t\t\tAND s.runid \u003d ?\n\t\t\tAND s.lineid \u003d ?\n\t\t\tAND s.enddatetime IS NOT NULL\n\t\t\tAND s.enddatetime \u003e s.startdatetime\n\t\tORDER BY s.startdatetime DESC\n\t\"\"\"\n\n\ttry:\n\t\tparams \u003d [runId, lineId]\n\t\tdata \u003d system.db.runPrepQuery(query, params, dbName)\n\t\tcolumn_names \u003d data.getColumnNames()\n\t\tjson_data \u003d system.dataset.toPyDataSet(data)\n\n\t\tif data.getRowCount() \u003e 0:\n\t\t\tresult \u003d [\n\t\t\t\t{col: row[col] for col in column_names}\n\t\t\t\tfor row in json_data\n\t\t\t]\n\t\telse:\n\t\t\tresult \u003d []\n\n\t\treturn result\n\n\texcept Exception as e:\n\t\tlogger.error(\u0027Downtime query failed: \u0027 + str(e))\n\t\treturn []",
                  "type": "script"
                }
              ],
              "type": "tag"
            }
          }
        },
