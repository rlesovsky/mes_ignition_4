{
  "custom": {},
  "params": {
    "lineID": 39,
    "tagPath": "[default]Enterprise/Site/Area/Line 1/Line"
  },
  "propConfig": {
    "params.lineID": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.tagPath": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 176,
      "width": 398
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "children": [
              {
                "meta": {
                  "name": "icon"
                },
                "position": {
                  "basis": "24px",
                  "shrink": 0
                },
                "props": {
                  "path": "material/stop_circle",
                  "style": {
                    "color": "#ef4444",
                    "marginRight": 10
                  }
                },
                "type": "ia.display.icon"
              },
              {
                "meta": {
                  "name": "title"
                },
                "position": {
                  "grow": 1
                },
                "props": {
                  "style": {
                    "color": "#7088a8",
                    "fontSize": 10,
                    "fontWeight": "600",
                    "letterSpacing": "0.07em"
                  },
                  "text": "CONFIRM STOP WORK ORDER"
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "header"
            },
            "position": {
              "basis": "50px",
              "shrink": 0
            },
            "props": {
              "alignItems": "center",
              "style": {
                "backgroundColor": "#16202e",
                "borderBottom": "1px solid #1b2432",
                "padding": "8px 14px"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "message"
                },
                "props": {
                  "style": {
                    "color": "#a8b8ce",
                    "fontFamily": "\u0027IBM Plex Sans\u0027, -apple-system, sans-serif",
                    "fontSize": 14,
                    "textAlign": "center"
                  },
                  "text": "Are you sure you want to stop the current run?"
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "body"
            },
            "position": {
              "grow": 1
            },
            "props": {
              "alignItems": "center",
              "direction": "column",
              "justifyContent": "center",
              "style": {
                "padding": "20px 14px"
              }
            },
            "type": "ia.container.flex"
          },
          {
            "children": [
              {
                "events": {
                  "component": {
                    "onActionPerformed": {
                      "config": {
                        "script": "\ttagPath \u003d self.view.params.tagPath + \"/Line\"\n\t\n\trunID \u003d system.tag.readBlocking(tagPath + \"/OEE/RunID\")[0].value\n\t\n\tmes_core.run.stopRun(runID)\n\t\n\tsystem.perspective.closePopup(\"\")"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
                "meta": {
                  "name": "yes"
                },
                "position": {
                  "basis": "0px",
                  "grow": 1
                },
                "props": {
                  "style": {
                    "backgroundColor": "#ef4444",
                    "borderRadius": 6,
                    "borderStyle": "none"
                  },
                  "text": "Stop Run",
                  "textStyle": {
                    "color": "#ffffff",
                    "fontFamily": "\u0027IBM Plex Sans\u0027, -apple-system, sans-serif",
                    "fontSize": 13,
                    "fontWeight": "600"
                  }
                },
                "type": "ia.input.button"
              },
              {
                "events": {
                  "component": {
                    "onActionPerformed": {
                      "config": {
                        "script": "\tsystem.perspective.closePopup(\"\")"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
                "meta": {
                  "name": "no"
                },
                "position": {
                  "basis": "0px",
                  "grow": 1
                },
                "props": {
                  "style": {
                    "backgroundColor": "transparent",
                    "border": "1px solid #1b2432",
                    "borderRadius": 6
                  },
                  "text": "Cancel",
                  "textStyle": {
                    "color": "#a8b8ce",
                    "fontFamily": "\u0027IBM Plex Sans\u0027, -apple-system, sans-serif",
                    "fontSize": 13,
                    "fontWeight": "600"
                  }
                },
                "type": "ia.input.button"
              }
            ],
            "meta": {
              "name": "buttons"
            },
            "position": {
              "basis": "55px",
              "shrink": 0
            },
            "props": {
              "style": {
                "borderTop": "1px solid #1b2432",
                "gap": 8,
                "padding": "10px 14px"
              }
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "root"
        },
        "position": {
          "grow": 1
        },
        "props": {
          "direction": "column",
          "style": {
            "backgroundColor": "#111822",
            "border": "1px solid #1b2432",
            "borderRadius": 8,
            "overflow": "hidden"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "backgroundColor": "#0d1117",
        "borderTopLeftRadius": 1
      }
    },
    "type": "ia.container.flex"
  }
}