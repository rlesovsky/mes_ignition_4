                          "config": {
                            "script": "\timport maintainx.workrequests as wr\n\n\troot \u003d self.parent.parent\n\tcontent \u003d root.getChild(\u0027content\u0027)\n\trequest_section \u003d content.getChild(\u0027request_section\u0027)\n\n\ttitle \u003d request_section.getChild(\u0027title_row\u0027).getChild(\u0027title_input\u0027).props.text\n\tdesc \u003d request_section.getChild(\u0027desc_row\u0027).getChild(\u0027desc_input\u0027).props.text\n\n\t# Try to get priority from custom, default to MEDIUM if not set\n\ttry:\n\t\tpriority \u003d self.view.custom.selectedPriority\n\texcept:\n\t\tpriority \u003d \u0027MEDIUM\u0027\n\n\tif not title or title.strip() \u003d\u003d \u0027\u0027:\n\t\tsystem.perspective.print(\u0027Title is required\u0027)\n\t\treturn\n\n\tresult \u003d wr.createSimple(\n\t\ttitle \u003d title,\n\t\tdescription \u003d desc if desc else \u0027\u0027,\n\t\tpriority \u003d priority if priority else \u0027MEDIUM\u0027\n\t)\n\n\tif result[\u0027success\u0027]:\n\t\tsystem.tag.writeBlocking(\n\t\t\t[\"[default]Enterprise/Site/Area/Line 1/Maintain X/Maint Requested\"],\n\t\t\t[True]\n\t\t)\n\t\tsystem.perspective.print(\u0027Work Request Created: WR-\u0027 + str(result[\u0027workRequestId\u0027]))\n\t\tsystem.perspective.closePopup(\u0027\u0027)\n\telse:\n\t\tsystem.perspective.print(\u0027Error: \u0027 + str(result[\u0027error\u0027]))"
