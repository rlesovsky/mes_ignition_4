          {
            "children": [
              {
                "events": {
                  "component": {
                    "onActionPerformed": {
                      "config": {
                        "script": "\n    logger \u003d system.util.getLogger(\u0027Schedule\u0027)\n    \n    # Get current timestamp\n    timestamp \u003d system.date.now()\n    \n    # Define database name\n    db \u003d \u0027mes_core\u0027\n    \n    # Define insert query for PostgreSQL\n    query \u003d \u0027\u0027\u0027INSERT INTO schedule (lineid, workorderid, scheduletype, note, schedulestartdatetime, schedulefinishdatetime, quantity, enteredby, \"TimeStamp\") \n               VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\u0027\u0027\u0027\n    \n    # Define validation query for WorkOrderID\n    validation_query \u003d \u0027\u0027\u0027SELECT id FROM workorder WHERE id \u003d ?\u0027\u0027\u0027\n    \n    try:\n        # Gather parameters\n        lineID \u003d self.view.params.lineID\n        \n        # Use dictionary-style access for array items\n        workOrders \u003d list(self.view.custom.workOrders)\n        if not workOrders or len(workOrders) \u003d\u003d 0:\n            logger.error(\"No work orders selected\")\n            return\n        workOrderID \u003d workOrders[0][\"ID\"]\n        \n        scheduleType \u003d 1\n        \n        logger.info(\"lineID: {}, workOrderID: {}\".format(lineID, workOrderID))\n        \n        # Get input values from the new structure\n        schedule_details \u003d self.parent.parent.getChild(\u0027schedule_details\u0027)\n        startDate \u003d schedule_details.getChild(\u0027schedule\u0027).getChild(\u0027DateTimeInput\u0027).props.value\n        finishDate \u003d schedule_details.getChild(\u0027schedule\u0027).getChild(\u0027DateTimeInput_0\u0027).props.value\n        quantity \u003d schedule_details.getChild(\u0027quantity\u0027).getChild(\u0027NumericEntryField\u0027).props.value\n        note \u003d schedule_details.getChild(\u0027notes\u0027).getChild(\u0027TextArea\u0027).props.text\n        userName \u003d \u0027Randy L\u0027\n        \n        logger.info(\"startDate: {}, type: {}\".format(startDate, type(startDate)))\n        logger.info(\"finishDate: {}, type: {}\".format(finishDate, type(finishDate)))\n        logger.info(\"quantity: {}, type: {}\".format(quantity, type(quantity)))\n        logger.info(\"note: {}\".format(note))\n        \n        # Check for None values\n        if lineID is None:\n            logger.error(\"lineID is None\")\n            return\n        if workOrderID is None:\n            logger.error(\"workOrderID is None\")\n            return\n        if startDate is None:\n            logger.error(\"startDate is None\")\n            return\n        if finishDate is None:\n            logger.error(\"finishDate is None\")\n            return\n        \n        # Convert dates if they\u0027re strings (Perspective DateTimeInput returns ISO strings)\n        if isinstance(startDate, basestring) or isinstance(startDate, str):\n            startDate \u003d system.date.parse(startDate, \"yyyy-MM-dd\u0027T\u0027HH:mm:ss\")\n        if isinstance(finishDate, basestring) or isinstance(finishDate, str):\n            finishDate \u003d system.date.parse(finishDate, \"yyyy-MM-dd\u0027T\u0027HH:mm:ss\")\n        \n        logger.info(\"Converted startDate: {}, finishDate: {}\".format(startDate, finishDate))\n        \n        # Validate WorkOrderID exists\n        validation_result \u003d system.db.runPrepQuery(validation_query, [workOrderID], db)\n        \n        if validation_result.getRowCount() \u003d\u003d 0:\n            logger.error(\u0027Invalid WorkOrderID: {} does not exist\u0027.format(workOrderID))\n            return\n        \n        logger.info(\"WorkOrderID validated\")\n        \n        # Ensure quantity is an integer\n        if quantity is None:\n            quantity \u003d 0\n        quantity \u003d int(quantity)\n        \n        # Ensure note is not None\n        if note is None:\n            note \u003d \"\"\n        \n        logger.info(\"About to insert with params: lineID\u003d{}, workOrderID\u003d{}, scheduleType\u003d{}, note\u003d{}, startDate\u003d{}, finishDate\u003d{}, quantity\u003d{}, userName\u003d{}, timestamp\u003d{}\".format(\n            lineID, workOrderID, scheduleType, note, startDate, finishDate, quantity, userName, timestamp))\n        \n        # Execute the insert query\n        result \u003d system.db.runPrepUpdate(query, [lineID, workOrderID, scheduleType, note, startDate, finishDate, quantity, userName, timestamp], db)\n        \n        logger.info(\"Insert result: {}\".format(result))\n        \n        # Close the popup if insert is successful\n        if result \u003d\u003d 1:\n            system.perspective.closePopup(\u0027\u0027)\n            \n    except Exception as e:\n        import traceback\n        logger.error(\u0027Insert failed: {}\u0027.format(str(e)))\n        logger.error(\u0027Traceback: {}\u0027.format(traceback.format_exc()))"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
