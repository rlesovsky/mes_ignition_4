    "custom.unitScheduled": {
      "binding": {
        "config": {
          "expression": "now()"
        },
        "transforms": [
          {
            "code": "\n    # Define database name\n    dbName \u003d \"mes_core\"\n    \n    # Base query with parameterized WorkOrderID\n    query \u003d \"\"\"\n        SELECT SUM(quantity) AS \\\"TotalQuantity\\\"\n        FROM schedule\n        WHERE workorderid \u003d ?\n    \"\"\"\n    \n    params \u003d []\n    try:\n        # Get WorkOrderID from root container property\n        workOrderID \u003d self.custom.workOrders[0].ID\n        \n        params.append(workOrderID)\n        \n        # Execute the query\n        data \u003d system.db.runPrepQuery(query, params, dbName)\n        \n        # Convert dataset to JSON for Perspective compatibility\n        json_data \u003d system.dataset.toPyDataSet(data)\n        result \u003d [\n            {\n                col: row[col]\n                for col in data.getColumnNames()\n            }\n            for row in json_data\n        ]\n        return result\n        \n    except Exception as e:\n        system.util.getLogger(\"ScriptLogger\").error(\"Query failed: {}\".format(str(e)))\n        return []",
            "type": "script"
          }
        ],
        "type": "expr"
      },
      "persistent": true
    },
    "custom.workOrders": {
      "binding": {
        "config": {
          "expression": "now()"
        },
        "transforms": [
          {
            "code": "\n    # Define database name\n    dbName \u003d \"mes_core\"\n    \n    # Base query matching your Vision query\n    query \u003d \"\"\"\n        SELECT id AS \\\"ID\\\", workorder AS \\\"WorkOrder\\\", productcode AS \\\"ProductCode\\\", quantity AS \\\"Quantity\\\"\n        FROM workorder\n        WHERE id \u003d ?\n    \"\"\"\n    \n    params \u003d []\n    try:\n        # Get WorkOrderID from root container property\n        workOrderID \u003d self.params.id\n        \n        params.append(workOrderID)\n        \n        # Execute the query\n        data \u003d system.db.runPrepQuery(query, params, dbName)\n        \n        # Convert dataset to JSON for Perspective compatibility\n        json_data \u003d system.dataset.toPyDataSet(data)\n        result \u003d [\n            {\n                col: row[col]\n                for col in data.getColumnNames()\n            }\n            for row in json_data\n        ]\n        return result\n        \n    except Exception as e:\n        system.util.getLogger(\"ScriptLogger\").error(\"Query failed: {}\".format(str(e)))\n        return []",
            "type": "script"
          }
        ],
        "type": "expr"
      },
      "persistent": true
    },
