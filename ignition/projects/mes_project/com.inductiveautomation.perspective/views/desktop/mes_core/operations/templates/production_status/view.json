                        "expression": "if(tag({view.params.tagPath} + \"/Line/OEE/WorkOrder[0,4]\") \u003e 0,\n  tag({view.params.tagPath} + \"/Line/Outfeed\") / tag({view.params.tagPath} + \"/Line/OEE/WorkOrder[0,4]\") * 100,\n  0)"
                      },
                      "transforms": [
                        {
                          "code": "\tif value is None:\n\t\treturn \"#6b7280\"\n\ttry:\n\t\tpercentage \u003d float(value)\n\texcept (ValueError, TypeError):\n\t\treturn \"#6b7280\"\n\tpercentage \u003d max(0, min(100, percentage))\n\tif percentage \u003e\u003d 85:\n\t\treturn \"#10b981\"\n\telif percentage \u003e\u003d 70:\n\t\treturn \"#3b82f6\"\n\telif percentage \u003e\u003d 50:\n\t\treturn \"#f59e0b\"\n\telif percentage \u003e\u003d 30:\n\t\treturn \"#f97316\"\n\telse:\n\t\treturn \"#ef4444\"",
