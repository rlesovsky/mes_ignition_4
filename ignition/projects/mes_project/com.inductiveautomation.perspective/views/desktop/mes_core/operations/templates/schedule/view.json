                    "binding": {
                      "config": {
                        "fallbackDelay": 2.5,
                        "mode": "expression",
                        "tagPath": "now()"
                      },
                      "transforms": [
                        {
                          "code": "\n\tdbName \u003d \"mes_core\"\n\t\n\tquery \u003d \"\"\"\n\t\tSELECT\n\t\t\tsch.id AS \"ID\",\n\t\t\two.workorder AS \"Work Order\",\n\t\t\two.productcode AS \"Product Code\",\n\t\t\two.quantity AS \"Quantity\",\n\t\t\tsch.schedulestartdatetime AS \"Start Date\"\n\t\tFROM workorder wo\n\t\tINNER JOIN schedule sch ON sch.workorderid \u003d wo.id\n\t\tWHERE wo.closed \u003d false\n\t\tAND sch.lineid \u003d ?\n\t\tAND sch.id NOT IN (SELECT scheduleid FROM run)\n\t\tORDER BY sch.schedulestartdatetime, sch.schedulefinishdatetime, wo.workorder\n\t\"\"\"\n\t\n\ttry:\n\t\ttag_path \u003d self.view.params.tagPath + \"/Line/Line ID\"\n\t\tline_id_result \u003d system.tag.readBlocking([tag_path])[0]\n\t\t\n\t\tif line_id_result.quality.isGood():\n\t\t\tline_id \u003d line_id_result.value\n\t\telse:\n\t\t\traise ValueError(\"Failed to read tag value for line_id\")\n\t\t\n\t\tdata \u003d system.db.runPrepQuery(query, [line_id], dbName)\n\t\tcolumn_names \u003d data.getColumnNames()\n\t\tjson_data \u003d system.dataset.toPyDataSet(data)\n\t\t\n\t\tif data.getRowCount() \u003e 0:\n\t\t\tresult \u003d [\n\t\t\t\t{col: row[col] for col in column_names}\n\t\t\t\tfor row in json_data\n\t\t\t]\n\t\telse:\n\t\t\tresult \u003d [\n\t\t\t\t{col: None for col in column_names}\n\t\t\t]\n\t\t\n\t\treturn result\n\t\n\texcept Exception as e:\n\t\tsystem.util.getLogger(\"ScriptLogger\").error(\"Query failed: {}\".format(str(e)))\n\t\treturn [\n\t\t\t{\n\t\t\t\t\u0027ID\u0027: None,\n\t\t\t\t\u0027Work Order\u0027: None,\n\t\t\t\t\u0027Product Code\u0027: None,\n\t\t\t\t\u0027Quantity\u0027: None,\n\t\t\t\t\u0027Start Date\u0027: None\n\t\t\t}\n\t\t]",
                          "type": "script"
                        }
                      ],
                      "type": "tag"
                    }
