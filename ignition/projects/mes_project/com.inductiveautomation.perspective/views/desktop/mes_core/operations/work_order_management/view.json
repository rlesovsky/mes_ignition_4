            "propConfig": {
              "props.items": {
                "binding": {
                  "config": {
                    "expression": "now()"
                  },
                  "transforms": [
                    {
                      "code": "\n\tdbName \u003d \"mes_core\"\n\tlineID \u003d self.view.custom.id\n\t\n\ttry:\n\t\tquery \u003d \u0027SELECT name FROM line WHERE id \u003d ?\u0027\n\t\tresult \u003d system.db.runPrepQuery(query, [lineID], dbName)\n\t\t\n\t\tif result.getRowCount() \u003e 0:\n\t\t\tlineName \u003d result.getValueAt(0, 0)\n\t\telse:\n\t\t\tlineName \u003d \"Line \" + str(lineID)\n\t\t\n\t\treturn [\n\t\t\t{\n\t\t\t\t\"id\": \"line\" + str(lineID),\n\t\t\t\t\"label\": lineName,\n\t\t\t\t\"iconConfig\": {\n\t\t\t\t\t\"path\": \"\",\n\t\t\t\t\t\"color\": \"\",\n\t\t\t\t\t\"style\": {}\n\t\t\t\t},\n\t\t\t\t\"headerStyle\": {\"classes\": \"\"},\n\t\t\t\t\"rowStyle\": {\"classes\": \"\"}\n\t\t\t}\n\t\t]\n\texcept Exception as e:\n\t\tsystem.util.getLogger(\"ScriptLogger\").error(\"Line query failed: {}\".format(str(e)))\n\t\treturn [\n\t\t\t{\n\t\t\t\t\"id\": \"line1\",\n\t\t\t\t\"label\": \"Line 1\",\n\t\t\t\t\"iconConfig\": {\n\t\t\t\t\t\"path\": \"\",\n\t\t\t\t\t\"color\": \"\",\n\t\t\t\t\t\"style\": {}\n\t\t\t\t},\n\t\t\t\t\"headerStyle\": {\"classes\": \"\"},\n\t\t\t\t\"rowStyle\": {\"classes\": \"\"}\n\t\t\t}\n\t\t]",
                      "type": "script"
                    }
                  ],
                  "type": "expr"
                }
              },
              "props.scheduledEvents": {
                "binding": {
                  "config": {
                    "expression": "now()"
                  },
                  "transforms": [
                    {
                      "code": "\n\tdbName \u003d \"mes_core\"\n\tlineID \u003d self.view.custom.id\n\t\n\tquery \u003d \"\"\"\n\t\tSELECT s.id AS \"ID\", s.lineid AS \"LineID\", s.workorderid AS \"WorkOrderID\",\n\t\t\ts.schedulestartdatetime AS \"StartDateTime\",\n\t\t\ts.schedulefinishdatetime AS \"FinishDateTime\",\n\t\t\ts.quantity AS \"Quantity\", w.workorder AS \"WorkOrder\"\n\t\tFROM schedule s\n\t\tINNER JOIN workorder w ON s.workorderid \u003d w.id\n\t\tWHERE s.lineid \u003d ?\n\t\tAND s.schedulestartdatetime \u003e\u003d ?\n\t\tAND s.schedulefinishdatetime \u003c\u003d ?\n\t\tORDER BY s.schedulestartdatetime\n\t\"\"\"\n\t\n\ttry:\n\t\tnow \u003d system.date.now()\n\t\tstart_date \u003d system.date.addDays(now, -7)\n\t\tend_date \u003d system.date.addDays(now, 30)\n\t\t\n\t\tdata \u003d system.db.runPrepQuery(query, [lineID, start_date, end_date], dbName)\n\t\tjson_data \u003d system.dataset.toPyDataSet(data)\n\t\tresult \u003d []\n\t\t\n\t\tfor row in json_data:\n\t\t\tstart_date_time \u003d row[\"StartDateTime\"]\n\t\t\tfinish_date_time \u003d row[\"FinishDateTime\"]\n\t\t\twork_order \u003d row[\"WorkOrder\"]\n\t\t\tquantity \u003d row[\"Quantity\"]\n\t\t\tschedule_id \u003d row[\"ID\"]\n\t\t\t\n\t\t\tif start_date_time is None or finish_date_time is None:\n\t\t\t\tcontinue\n\t\t\t\n\t\t\ttry:\n\t\t\t\tstart_millis \u003d system.date.toMillis(start_date_time)\n\t\t\t\tend_millis \u003d system.date.toMillis(finish_date_time)\n\t\t\t\tstart_date_output \u003d system.date.fromMillis(start_millis)\n\t\t\t\tend_date_output \u003d system.date.fromMillis(end_millis)\n\t\t\texcept:\n\t\t\t\ttry:\n\t\t\t\t\tstart_date_output \u003d system.date.fromMillis(start_date_time.getTime())\n\t\t\t\t\tend_date_output \u003d system.date.fromMillis(finish_date_time.getTime())\n\t\t\t\texcept:\n\t\t\t\t\tcontinue\n\t\t\t\n\t\t\tlabel \u003d \"{} ({:,})\".format(work_order, quantity) if quantity else work_order\n\t\t\t\n\t\t\trow_result \u003d {\n\t\t\t\t\"itemId\": \"line\" + str(lineID),\n\t\t\t\t\"eventId\": str(schedule_id),\n\t\t\t\t\"startDate\": start_date_output,\n\t\t\t\t\"endDate\": end_date_output,\n\t\t\t\t\"label\": label,\n\t\t\t\t\"leadTime\": 0,\n\t\t\t\t\"leadStyle\": {\"classes\": \"\"},\n\t\t\t\t\"percentDone\": 0,\n\t\t\t\t\"style\": {\"classes\": \"\"}\n\t\t\t}\n\t\t\t\n\t\t\tresult.append(row_result)\n\t\t\n\t\treturn result\n\t\n\texcept Exception as e:\n\t\tsystem.util.getLogger(\"ScriptLogger\").error(\"Schedule query failed: {}\".format(str(e)))\n\t\treturn []",
                      "type": "script"
                    }
                  ],
                  "type": "expr"
                }
              }
