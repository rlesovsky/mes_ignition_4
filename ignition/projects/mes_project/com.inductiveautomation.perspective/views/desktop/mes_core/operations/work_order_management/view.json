                "props": {
                  "color": "#10b981",
                  "path": "material/add_circle_outline",
                  "style": {
                    "cursor": "pointer",
                    "marginLeft": 12
                  }
                },
                "type": "ia.display.icon"
              },
              {
                "events": {
                  "dom": {
                    "onClick": {
                      "config": {
                        "script": "\n    \"\"\"\n    Closes the selected work order by setting closed \u003d true\n    \"\"\"\n    logger \u003d system.util.getLogger(\"WorkOrder\")\n    \n    # Navigate from delete icon to table:\n    # delete -\u003e parent (header) -\u003e sibling (table_wrapper) -\u003e child (table)\n    table \u003d self.parent.getSibling(\"table_wrapper\").getChild(\"table\")\n    selection_data \u003d table.props.selection.data\n    \n    # Check if a row is selected\n    if not selection_data or len(selection_data) \u003d\u003d 0:\n        logger.warn(\"No work order selected\")\n        return\n    \n    # Get the selected row (convert to list to access by index)\n    row_data \u003d list(selection_data)[0]\n    workorder_id \u003d row_data[\"ID\"]\n    workorder_name \u003d row_data.get(\"WorkOrder\", \"Unknown\")\n    \n    logger.info(\"Closing Work Order ID: {}, Name: {}\".format(workorder_id, workorder_name))\n    \n    # Update the database - set closed \u003d true\n    query \u003d \"UPDATE workorder SET closed \u003d true WHERE id \u003d ?\"\n    \n    try:\n        system.db.runPrepUpdate(query, [workorder_id], \"mes_core\")\n        logger.info(\"Work Order ID {} has been closed\".format(workorder_id))\n        \n        # Refresh the table data\n        table.refreshBinding(\"props.data\")\n        \n    except Exception as e:\n        logger.error(\"Failed to close Work Order ID {}: {}\".format(workorder_id, str(e)))"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
                "meta": {
                  "name": "delete"
                },
                "position": {
                  "basis": "24px",
                  "shrink": 0
                },
                "props": {
                  "color": "#ef4444",
                  "path": "material/delete_forever",
                  "style": {
                    "cursor": "pointer",
                    "marginLeft": 8,
                    "marginRight": 10
                  }
                },
                "type": "ia.display.icon"
              }
