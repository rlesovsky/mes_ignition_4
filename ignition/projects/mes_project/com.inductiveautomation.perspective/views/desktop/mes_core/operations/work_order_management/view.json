                      "transforms": [
                        {
                          "code": "\n    dbName \u003d \"mes_core\"\n    \n    search_string \u003d self.view.params.get(\"searchFilter\", \"\")\n    \n    query \u003d \"\"\"\n        SELECT \n            w.id AS \"ID\",\n            w.workorder AS \"WorkOrder\",\n            w.productcode AS \"ProductCode\",\n            w.quantity AS \"QTY\",\n            w.closed AS \"Closed\",\n            w.hide AS \"Hide\",\n            w.\"TimeStamp\" AS \"TimeStamp\"\n        FROM workorder w\n        WHERE w.hide \u003d false\n        AND w.closed \u003d false\n    \"\"\"\n    \n    params \u003d []\n    \n    if search_string:\n        query +\u003d \" AND (w.workorder ILIKE ? OR w.productcode ILIKE ?)\"\n        params.append(\u0027%\u0027 + search_string + \u0027%\u0027)\n        params.append(\u0027%\u0027 + search_string + \u0027%\u0027)\n    \n    try:\n        data \u003d system.db.runPrepQuery(query, params, dbName)\n        \n        if data.getRowCount() \u003e 0:\n            column_names \u003d data.getColumnNames()\n            json_data \u003d system.dataset.toPyDataSet(data)\n            return [{ col: row[col] for col in column_names } for row in json_data]\n        else:\n            return []\n            \n    except Exception as e:\n        system.util.getLogger(\"ScriptLogger\").error(\"Query failed: {}\".format(str(e)))\n        return []",
                          "type": "script"
                        }
                      ],
