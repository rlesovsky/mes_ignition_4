{
  "custom": {},
  "params": {},
  "props": {
    "defaultSize": {
      "height": 32
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "children": [
              {
                "meta": {
                  "name": "company_label"
                },
                "position": {
                  "basis": "40px",
                  "shrink": 0
                },
                "props": {
                  "style": {
                    "classes": "labels/font",
                    "color": "#22C55E",
                    "fontFamily": "\u0027IBM Plex Sans\u0027, -apple-system, BlinkMacSystemFont, \u0027Segoe UI\u0027, Arial, sans-serif",
                    "fontSize": 12,
                    "fontWeight": 700
                  },
                  "text": "TAS"
                },
                "type": "ia.display.label"
              },
              {
                "meta": {
                  "name": "divider_dot"
                },
                "position": {
                  "basis": "16px",
                  "shrink": 0
                },
                "props": {
                  "style": {
                    "color": "#4A6080",
                    "textAlign": "center"
                  },
                  "text": "•"
                },
                "type": "ia.display.label"
              },
              {
                "children": [
                  {
                    "meta": {
                      "name": "theme_icon"
                    },
                    "position": {
                      "basis": "18px",
                      "shrink": 0
                    },
                    "props": {
                      "color": "#4A6080",
                      "path": "material/brightness_medium"
                    },
                    "type": "ia.display.icon"
                  }
                ],
                "events": {
                  "dom": {
                    "onClick": {
                      "config": {
                        "script": "\tif self.session.props.theme \u003d\u003d \u0027light\u0027:\n\t\tself.session.props.theme \u003d \u0027dark\u0027\n\telse:\n\t\tself.session.props.theme \u003d \u0027light\u0027"
                      },
                      "scope": "G",
                      "type": "script"
                    }
                  }
                },
                "meta": {
                  "name": "theme_toggle",
                  "tooltip": {
                    "enabled": true,
                    "text": "Toggle Light/Dark Mode"
                  }
                },
                "position": {
                  "basis": "32px",
                  "shrink": 0
                },
                "props": {
                  "alignItems": "center",
                  "justify": "center",
                  "style": {
                    "borderRadius": 4,
                    "classes": "ui_ux/hover_highlight",
                    "cursor": "pointer"
                  }
                },
                "type": "ia.container.flex"
              }
            ],
            "meta": {
              "name": "left_section"
            },
            "position": {
              "basis": "120px",
              "shrink": 0
            },
            "props": {
              "alignItems": "center"
            },
            "type": "ia.container.flex"
          },
          {
            "meta": {
              "name": "timestamp"
            },
            "position": {
              "grow": 1
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "fallbackDelay": 2.5,
                    "mode": "direct",
                    "tagPath": "[System]Gateway/CurrentDateTime"
                  },
                  "transforms": [
                    {
                      "formatType": "datetime",
                      "formatValue": {
                        "date": "short",
                        "time": "medium"
                      },
                      "type": "format"
                    }
                  ],
                  "type": "tag"
                }
              }
            },
            "props": {
              "style": {
                "classes": "labels/font labels/size_normal",
                "color": "#A8B8CE",
                "fontFamily": "\u0027IBM Plex Mono\u0027, Consolas, monospace",
                "fontSize": 11,
                "fontWeight": 400,
                "textAlign": "center"
              }
            },
            "type": "ia.display.label"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "status_dot"
                },
                "position": {
                  "basis": "8px",
                  "shrink": 0
                },
                "props": {
                  "style": {
                    "backgroundColor": "#22C55E",
                    "borderRadius": "50%",
                    "boxShadow": "0 0 6px #22C55E",
                    "height": "8px",
                    "marginRight": "8px",
                    "width": "8px"
                  }
                },
                "type": "ia.container.flex"
              },
              {
                "meta": {
                  "name": "redundancy_role"
                },
                "position": {
                  "basis": "80px",
                  "shrink": 0
                },
                "propConfig": {
                  "props.text": {
                    "binding": {
                      "config": {
                        "fallbackDelay": 2.5,
                        "mode": "direct",
                        "tagPath": "[System]Gateway/Redundancy/Role"
                      },
                      "type": "tag"
                    }
                  }
                },
                "props": {
                  "style": {
                    "classes": "labels/font labels/size_normal",
                    "color": "#4A6080",
                    "fontFamily": "\u0027IBM Plex Sans\u0027, -apple-system, BlinkMacSystemFont, \u0027Segoe UI\u0027, Arial, sans-serif",
                    "fontSize": 10,
                    "fontWeight": 400,
                    "textAlign": "right"
                  }
                },
                "type": "ia.display.label"
              }
            ],
            "meta": {
              "name": "right_section"
            },
            "position": {
              "basis": "100px",
              "shrink": 0
            },
            "props": {
              "alignItems": "center",
              "justify": "flex-end"
            },
            "type": "ia.container.flex"
          }
        ],
        "meta": {
          "name": "root"
        },
        "position": {
          "grow": 1
        },
        "props": {
          "alignItems": "center",
          "justify": "space-between",
          "style": {
            "backgroundColor": "#0D1117",
            "borderTop": "1px solid #1B2432",
            "classes": "mes-footer",
            "overflow": "hidden",
            "paddingLeft": 12,
            "paddingRight": 12
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "alignItems": "center",
      "justify": "space-between",
      "style": {
        "backgroundColor": "#0D1117",
        "borderTop": "1px solid rgba(255, 255, 255, 0.05)",
        "classes": "mes-footer",
        "overflow": "hidden",
        "paddingLeft": "12px",
        "paddingRight": "12px"
      }
    },
    "type": "ia.container.flex"
  }
}