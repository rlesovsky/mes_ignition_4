#!/usr/bin/env bash
# =============================================================================
# Git pre-commit hook
# Install: ./scripts/setup-git-hooks.sh
# =============================================================================
set -euo pipefail

echo "Running pre-commit checks..."

# 1. Clean resource.json timestamp noise
if [ -f scripts/clean-resource-json.sh ]; then
    bash scripts/clean-resource-json.sh --apply 2>/dev/null || true
fi

# 2. Check for committed secrets
SECRETS_FOUND=0
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

for file in $STAGED_FILES; do
    if [[ "$file" == *.gwbk ]] || [[ "$file" == ".env.example" ]]; then continue; fi
    if git diff --cached -- "$file" | grep -iE '(password|secret|token|api.key)\s*[:=]\s*["\x27]?[A-Za-z0-9]{8,}' >/dev/null 2>&1; then
        echo "WARNING: Possible secret in staged file: $file"
        SECRETS_FOUND=$((SECRETS_FOUND + 1))
    fi
done

if [ $SECRETS_FOUND -gt 0 ]; then
    echo "Found $SECRETS_FOUND file(s) with possible secrets."
    echo "Review and remove secrets, or use: git commit --no-verify"
    exit 1
fi

# 3. Validate docker-compose if changed
if echo "$STAGED_FILES" | grep -q "docker-compose"; then
    if command -v docker >/dev/null 2>&1 && [ -f .env ]; then
        docker compose config --quiet 2>/dev/null || { echo "docker-compose.yml validation failed"; exit 1; }
    fi
fi

echo "Pre-commit checks passed."
